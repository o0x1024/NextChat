{"content":"1\tpackage com.suyu.secexample.fastjson.controller;\n 2\t\n 3\timport com.alibaba.fastjson.JSON;\n 4\timport com.alibaba.fastjson.JSONObject;\n 5\timport com.suyu.secexample.fastjson.model.User;\n 6\timport org.springframework.stereotype.Controller;\n 7\timport org.springframework.ui.Model;\n 8\timport org.springframework.web.bind.annotation.*;\n 9\t\n10\t\n11\t@Controller\n12\tpublic class fastjsoncontroller {\n13\t\n14\t    @GetMapping(\"/fastjson\")\n15\t    public String input(){\n16\t        return \"fastjson/fastjson\";\n17\t    }\n18\t\n19\t    User user = new User();\n20\t\n21\t    @RequestMapping (\"fastjson\")\n22\t    public String fastjson1(@RequestBody String jsonData, Model model) {\n23\t            JSONObject jsonObject = JSON.parseObject(jsonData);\n24\t            user.setAge(jsonObject.get(\"age\").toString());\n25\t            user.setUsername(jsonObject.get(\"username\").toString());\n26\t            model.addAttribute(\"result\",user);\n27\t        return \"fastjson/fastjsonoutput\";\n28\t        }\n29\t\n30\t    @RequestMapping (\"fastjson2\")\n31\t    public String fastjson2( Model model) {\n32\t        model.addAttribute(\"result\",user);\n33\t        return \"fastjson/fastjsonoutput\";\n34\t    }\n35\t}","file_path":"/Users/a1024/code/SecExample/src/main/java/com/suyu/secexample/fastjson/controller/fastjsoncontroller.java","limit":2000,"offset":1}


