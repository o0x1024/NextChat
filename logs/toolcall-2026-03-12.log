ze;\n        const startY = Math.floor(this.canvas.height / this.gridSize / 2) * this.gridSize;\n        \n        // 初始长度为3\n        for (let i = 0; i < 3; i++) {\n            this.snake.push({\n                x: startX - i * this.gridSize,\n                y: startY\n            });\n        }\n        \n        this.direction = 'right';\n        this.nextDirection = 'right';\n    }\n    \n    generateFood() {\n        let foodX, foodY;\n        let validPosition = false;\n        \n        while (!validPosition) {\n            foodX = Math.floor(Math.random() * (this.canvas.width / this.gridSize)) * this.gridSize;\n            foodY = Math.floor(Math.random() * (this.canvas.height / this.gridSize)) * this.gridSize;\n            \n            // 检查是否与蛇身重叠\n            validPosition = !this.snake.some(segment => segment.x === foodX && segment.y === foodY);\n            \n            // 检查是否与障碍物重叠\n            if (validPosition) {\n                validPosition = !this.obstacles.some(obs => obs.x === foodX && obs.y === foodY);\n            }\n        }\n        \n        this.food = { x: foodX, y: foodY };\n    }\n    \n    generateObstacles() {\n        this.obstacles = [];\n        const obstacleCount = Math.floor(Math.random() * 4) + 5; // 5-8个障碍物\n        \n        for (let i = 0; i < obstacleCount; i++) {\n            let obstacleX, obstacleY;\n            let validPosition = false;\n            \n            while (!validPosition) {\n                obstacleX = Math.floor(Math.random() * (this.canvas.width / this.gridSize)) * this.gridSize;\n                obstacleY = Math.floor(Math.random() * (this.canvas.height / this.gridSize)) * this.gridSize;\n                \n                // 检查是否与蛇起始位置重叠\n                const startX = Math.floor(this.canvas.width / this.gridSize / 2) * this.gridSize;\n                const startY = Math.floor(this.canvas.height / this.gridSize / 2) * this.gridSize;\n                const isNearStart = Math.abs(obstacleX - startX)