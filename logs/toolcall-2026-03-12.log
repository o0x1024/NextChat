{"content":"/* 霓虹贪吃蛇 - 赛博朋克风格CSS */\n:root {\n    --bg-dark: #0a0a0f;\n    --bg-darker: #050508;\n    --neon-cyan: #00ffff;\n    --neon-magenta: #ff00ff;\n    --neon-blue: #0066ff;\n    --neon-green: #00ff99;\n    --neon-yellow: #ffff00;\n    --glass-bg: rgba(255, 255, 255, 0.05);\n    --glass-border: rgba(255, 255, 255, 0.1);\n    --glow-shadow: 0 0 10px, 0 0 20px, 0 0 30px;\n}\n\n* {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n}\n\nbody {\n    font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif;\n    background: linear-gradient(135deg, var(--bg-dark) 0%, #1a1a2e 100%);\n    color: #fff;\n    min-height: 100vh;\n    overflow-x: hidden;\n}\n\n.container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 20px;\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n}\n\n/* 头部样式 */\n.game-header {\n    background: var(--glass-bg);\n    backdrop-filter: blur(10px);\n    border: 1px solid var(--glass-border);\n    border-radius: 15px;\n    padding: 20px;\n    margin-bottom: 20px;\n    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n    border-image: linear-gradient(45deg, var(--neon-cyan), var(--neon-magenta)) 1;\n}\n\n.game-header h1 {\n    font-size: 2.5rem;\n    margin-bottom: 15px;\n    text-align: center;\n    background: linear-gradient(45deg, var(--neon-cyan), var(--neon-magenta));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);\n}\n\n.game-stats {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\n    gap: 15px;\n}\n\n.stat {\n    background: rgba(0, 0, 0, 0.3);\n    padding: 12px 20px;\n    border-radius: 10px;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    transition: all 0.3s ease;\n}\n\n.stat:hover {\n    border-color: var(--neon-cyan);\n    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);\n}\n\n.stat-label {\n    color: #aaa;\n    font-size: 0.9rem;\n}\n\n.stat-value {\n    font-size: 1.3rem;\n    font-weight: bold;\n    color: var(--neon-green);\n    text-shadow: 0 0 5px rgba(0, 255, 153, 0.5);\n}\n\n/* 主游戏区域 */\n.game-main {\n    display: grid;\n    grid-template-columns: 1fr 300px;\n    gap: 20px;\n    flex: 1;\n}\n\n.game-area {\n    position: relative;\n    background: var(--bg-darker);\n    border-radius: 15px;\n    overflow: hidden;\n    border: 2px solid rgba(255, 255, 255, 0.1);\n}\n\n#game-canvas {\n    display: block;\n    width: 100%;\n    height: 100%;\n    background: var(--bg-dark);\n}\n\n.game-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background: rgba(0, 0, 0, 0.85);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    backdrop-filter: blur(5px);\n    z-index: 10;\n}\n\n.overlay-content {\n    background: var(--glass-bg);\n    border: 1px solid var(--glass-border);\n    border-radius: 15px;\n    padding: 40px;\n    text-align: center;\n    max-width: 500px;\n    width: 90%;\n    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);\n    border-image: linear-gradient(45deg, var(--neon-blue), var(--neon-magenta)) 1;\n}\n\n#overlay-title {\n    font-size: 2.5rem;\n    margin-bottom: 20px;\n    color: var(--neon-cyan);\n    text-shadow: var(--glow-shadow) rgba(0, 255, 255, 0.3);\n}\n\n#overlay-message {\n    font-size: 1.2rem;\n    margin-bottom: 30px;\n    color: #ccc;\n}\n\n.overlay-buttons {\n    display: flex;\n    gap: 15px;\n    justify-content: center;\n}\n\n/* 游戏控制面板 */\n.game-controls {\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n}\n\n.control-section {\n    background: var(--glass-bg);\n    backdrop-filter: blur(10px);\n    border: 1px solid var(--glass-border);\n    border-radius: 15px;\n    padding: 20px;\n    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n}\n\n.control-section h3 {\n    font-size: 1.3rem;\n    margin-bottom: 15px;\n    color: var(--neon-yellow);\n    display: flex;\n    align-items: center;\n    gap: 10px;\n}\n\n.powerup-display {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n}\n\n.powerup-item {\n    display: flex;\n    align-items: center;\n    gap: 15px;\n    padding: 12px;\n    background: rgba(0, 0, 0, 0.3);\n    border-radius: 8px;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    transition: all 0.3s ease;\n}\n\n.powerup-item:hover {\n    border-color: var(--neon-magenta);\n    box-shadow: 0 0 10px rgba(255, 0, 255, 0.3);\n}\n\n.powerup-icon {\n    font-size: 1.5rem;\n    width: 40px;\n    height: 40px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 8px;\n}\n\n.powerup-name {\n    flex: 1;\n    font-weight: 500;\n}\n\n.powerup-timer {\n    font-family: 'Courier New', monospace;\n    color: var(--neon-green);\n    font-weight: bold;\n    min-width: 30px;\n    text-align: right;\n}\n\n.instructions {\n    margin-bottom: 20px;\n}\n\n.instructions p {\n    margin-bottom: 8px;\n    color: #ccc;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n}\n\n.touch-controls {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n}\n\n.touch-row {\n    display: flex;\n    gap: 10px;\n}\n\n.touch-btn {\n    width: 70px;\n    height: 70px;\n    border: none;\n    background: rgba(0, 0, 0, 0.3);\n    border: 2px solid rgba(255, 255, 255, 0.2);\n    border-radius: 50%;\n    color: white;\n    font-size: 1.8rem;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.touch-btn:hover {\n    background: rgba(0, 255, 255, 0.1);\n    border-color: var(--neon-cyan);\n    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);\n    transform: scale(1.05);\n}\n\n.touch-btn:active {\n    transform: scale(0.95);\n}\n\n/* 按钮样式 */\n.btn {\n    padding: 12px 24px;\n    border: none;\n    border-radius: 8px;\n    font-size: 1rem;\n    font-weight: 600;\n    cursor: pointer;\n    transition: all 0.3s ease;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n}\n\n.btn-primary {\n    background: linear-gradient(45deg, var(--neon-cyan), var(--neon-blue));\n    color: white;\n    border: 1px solid rgba(255, 255, 255, 0.2);\n}\n\n.btn-primary:hover {\n    box-shadow: 0 0 20px rgba(0, 255, 255, 0.4);\n    transform: translateY(-2px);\n}\n\n.btn-secondary {\n    background: rgba(255, 255, 255, 0.1);\n    color: white;\n    border: 1px solid rgba(255, 255, 255, 0.2);\n}\n\n.btn-secondary:hover {\n    background: rgba(255, 255, 255, 0.2);\n    border-color: var(--neon-magenta);\n}\n\n.btn-icon {\n    padding: 10px 15px;\n    background: rgba(255, 255, 255, 0.05);\n    color: white;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.btn-icon:hover {\n    background: rgba(255, 255, 255, 0.1);\n    border-color: var(--neon-yellow);\n}\n\n/* 页脚样式 */\n.game-footer {\n    margin-top: 20px;\n    padding: 20px;\n    background: var(--glass-bg);\n    backdrop-filter: blur(10px);\n    border: 1px solid var(--glass-border);\n    border-radius: 15px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n}\n\n.footer-info {\n    color: #aaa;\n}\n\n.footer-info p {\n    margin-bottom: 5px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n}\n\n.footer-buttons {\n    display: flex;\n    gap: 10px;\n}\n\n/* 响应式设计 */\n@media (max-width: 1024px) {\n    .game-main {\n        grid-template-columns: 1fr;\n    }\n    \n    .game-controls {\n        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n    }\n}\n\n@media (max-width: 768px) {\n    .container {\n        padding: 10px;\n    }\n    \n    .game-header h1 {\n        font-size: 2rem;\n    }\n    \n    .game-stats {\n        grid-template-columns: repeat(2, 1fr);\n    }\n    \n    .touch-btn {\n        width: 60px;\n  