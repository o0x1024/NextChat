{"file_path": "/Users/a1024/code/apptest/game.js", "content": "// 霓虹贪吃蛇游戏主逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2; // 初始2条命\n        this.speed = 1.0;\n        this.foodEaten = 0;\n        \n        // 游戏参数\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        this.gameSpeed = 150; // 初始速度（毫秒）\n        \n        // 蛇相关\n        this.snake = [];\n        this.snakeDirection = 'right';\n        this.nextDirection = 'right';\n        \n        // 食物相关\n        this.food = { x: 0, y: 0 };\n        \n        // 道具相关\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 游戏循环\n        this.gameLoop = null;\n        this.lastUpdateTime = 0;\n        \n        // 初始化\n        this.init();\n    }\n    \n    init() {\n        // 设置Canvas尺寸\n        this.resizeCanvas();\n        window.addEventListener('resize', () => this.resizeCanvas());\n        \n        // 初始化UI\n        this.updateUI();\n        \n        // 绑定事件\n        this.bindEvents();\n        \n        // 生成初始障碍物\n        this.generateObstacles();\n        \n        // 开始游戏循环\n        this.startGameLoop();\n    }\n    \n    resizeCanvas() {\n        const container = this.canvas.parentElement;\n        const containerWidth = container.clientWidth;\n        const containerHeight = container.clientHeight;\n        \n        // 保持16:9比例\n        const targetHeight = containerWidth * 0.75;\n        const targetWidth = containerHeight * 1.333;\n        \n        if (targetHeight <= containerHeight) {\n            this.canvas.width = containerWidth;\n            this.canvas.height = targetHeight;\n        } else {\n            this.canvas.width = targetWidth;\n            this.canvas.height = containerHeight;\n        }\n        \n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        \n        // 重新生成食物和障碍物\n        if (this.gameState === 'playing') {\n            this.generateFood();\n            this.generateObstacles();\n        }\n    }\n    \n    bindEvents() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => this.handleKeyDown(e));\n        \n        // 按钮控制\n        document.getElementById('start-btn').addEventListener('click', () => this.startGame());\n        document.getElementById('restart-btn').addEventListener('click', () => this.restartGame());\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => this.changeDirection('up'));\n        document.getElementById('down-btn').addEventListener('click', () => this.changeDirection('down'));\n        document.getElementById('left-btn').addEventListener('click', () => this.changeDirection('left'));\n        document.getElementById('right-btn').addEventListener('click', () => this.changeDirection('right'));\n        \n        // 设置按钮\n        document.getElementById('settings-btn').addEventListener('click', () => this.showSettings());\n        document.getElementById('sound-btn').addEventListener('click', () => this.toggleSound());\n    }\n    \n    handleKeyDown(e) {\n        switch(e.key) {\n            case 'ArrowUp':\n            case 'w':\n            case 'W':\n                this.changeDirection('up');\n                break;\n            case 'ArrowDown':\n            case 's':\n            case 'S':\n                this.changeDirection('down');\n                break;\n            case 'ArrowLeft':\n            case 'a':\n            case 'A':\n                this.changeDirection('left');\n                break;\n            case 'ArrowRight':\n            case 'd':\n            case 'D':\n                this.changeDirection('right');\n                break;\n            case ' ':\n                if (this.gameState === 'menu' || this.gameState === 'gameover') {\n                    this.startGame();\n                } else if (this.gameState === 'playing') {\n                    this.togglePause();\n                }\n                break;\n            case 'Escape':\n                this.togglePause();\n                break;\n        }\n    }\n    \n    changeDirection(direction) {\n        // 防止直接反向移动\n        if (\n            (direction === 'up' && this.snakeDirection !== 'down') ||\n            (direction === 'down' && this.snakeDirection !== 'up') ||\n            (direction === 'left' && this.snakeDirection !== 'right') ||\n            (direction === 'right' && this.snakeDirection !== 'left')\n        ) {\n            this.nextDirection = direction;\n        }\n    }\n    \n    startGame() {\n        if (this.gameState === 'playing') return;\n        \n        // 重置游戏状态\n        this.gameState = 'playing';\n        this.score = 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodEaten = 0;\n        this.snakeDirection = 'right';\n        this.nextDirection = 'right';\n        \n        // 初始化蛇\n        this.snake = [\n            { x: 5, y: Math.floor(this.gridHeight / 2) },\n            { x: 4, y: Math.floor(this.gridHeight / 2) },\n            { x: 3, y: Math.floor(this.gridHeight / 2) }\n        ];\n        \n        // 清空道具\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 生成食物和障碍物\n        this.generateFood();\n        this.generateObstacles();\n        \n        // 更新UI\n        this.updateUI();\n        this.hideOverlay();\n    }\n    \n    restartGame() {\n        this.startGame();\n    }\n    \n    togglePause() {\n        if (this.gameState === 'playing') {\n            this.gameState = 'paused';\n            this.showOverlay('游戏暂停', '按空格键继续');\n        } else if (this.gameState === 'paused') {\n            this.gameState = 'playing';\n            this.hideOverlay();\n        }\n    }\n    \n    gameOver() {\n        this.gameState = 'gameover';\n        \n        // 更新最高分\n        if (this.score > this.highScore) {\n            this.highScore = this.score;\n            localStorage.setItem('neonSnakeHighScore', this.highScore);\n        }\n        \n        this.showOverlay('游戏结束', `最终得分: ${this.score}<br>最高分: ${this.highScore}`);\n    }\n    \n    update() {\n        if (this.gameState !== 'playing') return;\n        \n        // 更新方向\n        this.snakeDirection = this.nextDirection;\n        \n        // 移动蛇头\n        const head = { ...this.snake[0] };\n        \n        switch(this.snakeDirection) {\n            case 'up': head.y--; break;\n            case 'down': head.y++; break;\n            case 'left': head.x--; break;\n            case 'right': head.x++; break;\n        }\n        \n        // 穿墙处理\n        if (this.activePowerups.wallPass.active) {\n            if (head.x < 0) head.x = this.gridWidth - 1;\n            if (head.x >= this.gridWidth) head.x = 0;\n            if (head.y < 0) head.y = this.gridHeight - 1;\n            if (head.y >= this.gridHeight) head.y = 0;\n        }\n        \n        // 检查碰撞\n        if (!this.checkCollision(head)) {\n            // 添加新头\n            this.snake.unshift(head);\n            \n            // 检查是否吃到食物\n            if (head.x === this.food.x && head.y === this.food.