{"content": "// 霓虹贪吃蛇游戏主逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        this.gameOverlay = document.getElementById('game-overlay');\n        this.overlayTitle = document.getElementById('overlay-title');\n        this.overlayMessage = document.getElementById('overlay-message');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodCount = 0;\n        \n        // 游戏参数\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        this.gameSpeed = 150; // 毫秒\n        this.lastUpdate = 0;\n        \n        // 蛇\n        this.snake = [];\n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 食物\n        this.food = { x: 0, y: 0 };\n        \n        // 道具\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 初始化\n        this.init();\n        this.setupEventListeners();\n        this.updateUI();\n        this.gameLoop();\n    }\n    \n    init() {\n        // 初始化蛇\n        const startX = Math.floor(this.gridWidth / 2);\n        const startY = Math.floor(this.gridHeight / 2);\n        this.snake = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 生成第一个食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        document.getElementById('high-score').textContent = this.highScore;\n    }\n    \n    setupEventListeners() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            switch(e.key) {\n                case 'ArrowUp':\n                case 'w':\n                case 'W':\n                    if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: -1 };\n                    break;\n                case 'ArrowDown':\n                case 's':\n                case 'S':\n                    if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: 1 };\n                    break;\n                case 'ArrowLeft':\n                case 'a':\n                case 'A':\n                    if (this.snakeDirection.x === 0) this.nextDirection = { x: -1, y: 0 };\n                    break;\n                case 'ArrowRight':\n                case 'd':\n                case 'D':\n                    if (this.snakeDirection.x === 0) this.nextDirection = { x: 1, y: 0 };\n                    break;\n                case ' ':\n                    if (this.gameState === 'menu') this.startGame();\n                    else if (this.gameState === 'gameover') this.restartGame();\n                    break;\n            }\n        });\n        \n        // 按钮事件\n        document.getElementById('start-btn').addEventListener('click', () => this.startGame());\n        document.getElementById('restart-btn').addEventListener('click', () => this.restartGame());\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => {\n            if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: -1 };\n        });\n        document.getElementById('down-btn').addEventListener('click', () => {\n            if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: 1 };\n        });\n        document.getElementById('left-btn').addEventListener('click', () => {\n            if (this.snakeDirection.x === 0) this.nextDirection = { x: -1, y: 0 };\n        });\n        document.getElementById('right-btn').addEventListener('click', () => {\n            if (this.snakeDirection.x === 0) this.nextDirection = { x: 1, y: 0 };\n        });\n    }\n    \n    startGame() {\n        this.gameState = 'playing';\n        this.gameOverlay.style.display = 'none';\n        this.init();\n    }\n    \n    restartGame() {\n        this.score = 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodCount = 0;\n        this.gameState = 'playing';\n        this.gameOverlay.style.display = 'none';\n        this.init();\n        this.updateUI();\n    }\n    \n    gameLoop(timestamp) {\n        requestAnimationFrame((ts) => this.gameLoop(ts));\n        \n        if (this.gameState !== 'playing') return;\n        \n        if (timestamp - this.lastUpdate > this.gameSpeed / this.speed) {\n            this.update();\n            this.lastUpdate = timestamp;\n        }\n        \n        this.draw();\n    }\n    \n    update() {\n        // 更新方向\n        this.snakeDirection = { ...this.nextDirection };\n        \n        // 移动蛇头\n        const head = { ...this.snake[0] };\n        head.x += this.snakeDirection.x;\n        head.y += this.snakeDirection.y;\n        \n        // 穿墙检查\n        if (this.activePowerups.wallPass.active) {\n            if (head.x < 0) head.x = this.gridWidth - 1;\n            if (head.x >= this.gridWidth) head.x = 0;\n            if (head.y < 0) head.y = this.gridHeight - 1;\n            if (head.y >= this.gridHeight) head.y = 0;\n        }\n        \n        // 碰撞检测\n        if (!this.activePowerups.shield.active) {\n            // 墙壁碰撞\n            if (!this.activePowerups.wallPass.active) {\n                if (head.x < 0 || head.x >= this.gridWidth || \n                    head.y < 0 || head.y >= this.gridHeight) {\n                    this.handleCollision();\n                    return;\n                }\n            }\n            \n            // 自身碰撞\n            for (let i = 0; i < this.snake.length; i++) {\n                if (head.x === this.snake[i].x && head.y === this.snake[i].y) {\n                    this.handleCollision();\n                    return;\n                }\n            }\n            \n            // 障碍物碰撞\n            for (const obstacle of this.obstacles) {\n                if (head.x === obstacle.x && head.y === obstacle.y) {\n                    this.handleCollision();\n                    return;\n                }\n            }\n        }\n        \n        // 添加到蛇头\n        this.snake.unshift(head);\n        \n        // 食物检测\n        if (head.x === this.food.x && head.y === this.food.y) {\n            this.score += Math.floor(10 * this.speed);\n            this.foodCount++;\n            \n            // 每吃5个食物加速10%\n            if (this.foodCount % 5 === 0) {\n                this.speed = Math.min(this.speed + 0.1, 2.0);\n            }\n            \n            // 30%概率生成道具\n            if (Math.random() < 0.3 && this.powerups.length < 2) {\n                this.generatePowerup();\n            }\n            \n            this.generateFood();\n        } else {\n            // 没吃到食物，移除蛇尾\n            this.snake.pop();\n        }\n        \n        // 道具检测\n        for (let i = this.powerups.length - 1; i >= 0; i--) {\n            const powerup = this.powerups[i];\n            if (head.x === powerup.x && head.y === powerup.y) {\n                this.activatePowerup(powerup.type);\n                this.powerups.splice(i, 1);\n            }\n        }\n        \n        // 更新道具计时器\n        this.updatePowerupTimers();\n        \n        // 更新UI\n        this.updateUI();\n    }\n    \n    handleCollision() {\n        if (this.lives > 0) {\n            this.lives--;\n            // 复活逻辑 - 重置蛇位置\n            const startX = Math.floor(this.gridWidth / 2);\n            const startY = Math.floor(this.gridHe...<truncated 9586 chars>


