 startX = Math.floor(this.gridWidth / 2);\n        const startY = Math.floor(this.gridHeight / 2);\n        this.snake = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        this.highScoreElement.textContent = this.highScore;\n    }\n    \n    setupEventListeners() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            switch(e.key) {\n                case 'ArrowUp':\n                case 'w':\n                case 'W':\n                    if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: -1 };\n                    break;\n                case 'ArrowDown':\n                case 's':\n                case 'S':\n                    if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: 1 };\n                    break;\n                case 'ArrowLeft':\n                case 'a':\n                case 'A':\n                    if (this.snakeDirection.x === 0) this.nextDirection = { x: -1, y: 0 };\n                    break;\n                case 'ArrowRight':\n                case 'd':\n                case 'D':\n                    if (this.snakeDirection.x === 0) this.nextDirection = { x: 1, y: 0 };\n                    break;\n                case ' ':\n                    if (this.gameState === 'menu') {\n                        this.startGame();\n                    } else if (this.gameState === 'gameover') {\n                        this.restartGame();\n                    }\n                    break;\n                case 'Escape':\n                    if (this.gameState === 'playing') {\n                        this.pauseGame();\n                    } else if (this.gameState === 'paused') {\n                        this.resumeGame();\n                    }\n       