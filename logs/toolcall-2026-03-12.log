{"file_path": "/Users/a1024/code/apptest/game.js", "content": "// 霓虹贪吃蛇游戏主逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        this.gameOverlay = document.getElementById('game-overlay');\n        this.overlayTitle = document.getElementById('overlay-title');\n        this.overlayMessage = document.getElementById('overlay-message');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodEaten = 0;\n        \n        // 游戏元素\n        this.gridSize = 20;\n        this.snake = [];\n        this.food = null;\n        this.obstacles = [];\n        this.powerups = [];\n        \n        // 方向控制\n        this.direction = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 道具效果\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 游戏循环\n        this.lastRenderTime = 0;\n        this.gameSpeed = 150; // 毫秒\n        \n        // 初始化\n        this.init();\n        this.setupEventListeners();\n        this.updateUI();\n        this.showMenu();\n    }\n    \n    init() {\n        // 设置画布尺寸\n        this.canvas.width = 800;\n        this.canvas.height = 600;\n        \n        // 初始化蛇\n        this.resetSnake();\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        document.getElementById('high-score').textContent = this.highScore;\n    }\n    \n    resetSnake() {\n        this.snake = [];\n        const startX = Math.floor(this.canvas.width / this.gridSize / 2);\n        const startY = Math.floor(this.canvas.height / this.gridSize / 2);\n        \n        // 初始蛇长度为3\n        for (let i = 0; i < 3; i++) {\n            this.snake.push({\n                x: startX - i,\n                y: startY\n            });\n        }\n        \n        this.direction = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n    }\n    \n    generateFood() {\n        let food;\n        let validPosition = false;\n        \n        while (!validPosition) {\n            food = {\n                x: Math.floor(Math.random() * (this.canvas.width / this.gridSize)),\n                y: Math.floor(Math.random() * (this.canvas.height / this.gridSize))\n            };\n            \n            // 检查食物是否在蛇身上\n            validPosition = !this.snake.some(segment => \n                segment.x === food.x && segment.y === food.y\n            );\n            \n            // 检查食物是否在障碍物上\n            if (validPosition) {\n                validPosition = !this.obstacles.some(obstacle =>\n                    obstacle.x === food.x && obstacle.y === food.y\n                );\n            }\n        }\n        \n        this.food = food;\n    }\n    \n    generateObstacles() {\n        this.obstacles = [];\n        const obstacleCount = Math.floor(Math.random() * 4) + 5; // 5-8个障碍物\n        \n        for (let i = 0; i < obstacleCount; i++) {\n            let obstacle;\n            let validPosition = false;\n            \n            while (!validPosition) {\n                obstacle = {\n                    x: Math.floor(Math.random() * (this.canvas.width / this.gridSize)),\n                    y: Math.floor(Math.random() * (this.canvas.height / this.gridSize))\n                };\n                \n                // 检查障碍物位置是否有效\n                validPosition = true;\n                \n                // 不能和蛇重叠\n                if (this.snake.some(segment => \n                    segment.x === obstacle.x && segment.y === obstacle.y\n                )) {\n                    validPosition = false;\n                }\n                \n                // 不能和食物重叠\n                if (this.food && obstacle.x === this.food.x && obstacle.y === this.food.y) {\n                    validPosition = false;\n                }\n                \n                // 不能和其他障碍物重叠\n                if (this.obstacles.some(obs =>\n                    obs.x === obstacle.x && obs.y === obstacle.y\n                )) {\n                    validPosition = false;\n                }\n                \n                // 不能在蛇周围太近\n                if (validPosition) {\n                    for (const segment of this.snake) {\n                        const distance = Math.sqrt(\n                            Math.pow(segment.x - obstacle.x, 2) + \n                            Math.pow(segment.y - obstacle.y, 2)\n                        );\n                        if (distance < 3) {\n                            validPosition = false;\n                            break;\n                        }\n                    }\n                }\n            }\n            \n            this.obstacles.push(obstacle);\n        }\n    }\n    \n    setupEventListeners() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            switch(e.key) {\n                case 'ArrowUp':\n                case 'w':\n                case 'W':\n                    if (this.direction.y === 0) this.nextDirection = { x: 0, y: -1 };\n                    break;\n                case 'ArrowDown':\n                case 's':\n                case 'S':\n                    if (this.direction.y === 0) this.nextDirection = { x: 0, y: 1 };\n                    break;\n                case 'ArrowLeft':\n                case 'a':\n                case 'A':\n                    if (this.direction.x === 0) this.nextDirection = { x: -1, y: 0 };\n                    break;\n                case 'ArrowRight':\n                case 'd':\n                case 'D':\n                    if (this.direction.x === 0) this.nextDirection = { x: 1, y: 0 };\n                    break;\n                case ' ':\n                    if (this.gameState === 'menu') {\n                        this.startGame();\n                    } else if (this.gameState === 'playing') {\n                        this.togglePause();\n                    } else if (this.gameState === 'gameover') {\n                        this.restartGame();\n                    }\n                    break;\n                case 'Escape':\n                    if (this.gameState === 'playing') {\n                        this.togglePause();\n                    }\n                    break;\n            }\n        });\n        \n        // 按钮事件\n        document.getElementById('start-btn').addEventListener('click', () => {\n            if (this.gameState === 'menu') {\n                this.startGame();\n            }\n        });\n        \n        document.getElementById('restart-btn').addEventListener('click', () => {\n            this.restartGame();\n        });\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => {\n            if (this.direction.y === 0) this.nextDirection = { x: 0, y: -1 };\n        });\n        \n        document.getElementById('down-btn').addEventListener('click', () => {\n            if (this.direction.y === 0) this.nextDirection = { x: 0, y: 1 };\n        });\n        \n        document.getElementById('left-btn').addEventListener('click', () => {\n            if (this.direction.x === 0) this.nextDirection = { x: -1, y: 0 };\n        });\n        \n        document.getElementById('right-btn').addEventListener('click', () => {\n            if (this.direction.x === 0) this.nextDirection = { x: 1, y: 0 };\n        });\n        \n        // 设置按钮\n        document.getElementById('settings-btn').addEventListener('click', () => {\n            alert('设置功能开发中...');\n        });\n        \n        docum