keDirection.y === 0) this.nextDirection = { x: 0, y: -1 };\n                break;\n            case 'ArrowDown':\n            case 's':\n            case 'S':\n                if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: 1 };\n                break;\n            case 'ArrowLeft':\n            case 'a':\n            case 'A':\n                if (this.snakeDirection.x === 0) this.nextDirection = { x: -1, y: 0 };\n                break;\n            case 'ArrowRight':\n            case 'd':\n            case 'D':\n                if (this.snakeDirection.x === 0) this.nextDirection = { x: 1, y: 0 };\n                break;\n            case 'Escape':\n                this.togglePause();\n                break;\n        }\n    }\n    \n    changeDirection(x, y) {\n        if (this.gameState !== 'playing') return;\n        if (this.snakeDirection.x === -x && this.snakeDirection.y === -y) return; // 不能直接反向\n        this.nextDirection = { x, y };\n    }\n    \n    startGame() {\n        this.gameState = 'playing';\n        this.score = 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodEaten = 0;\n        \n        // 初始化蛇\n        this.snake = [\n            { x: Math.floor(this.gridWidth / 2), y: Math.floor(this.gridHeight / 2) },\n            { x: Math.floor(this.gridWidth / 2) - 1, y: Math.floor(this.gridHeight / 2) },\n            { x: Math.floor(this.gridWidth / 2) - 2, y: Math.floor(this.gridHeight / 2) }\n        ];\n        \n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 清空道具\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 隐藏菜单\n        this.gameOverlay.style.display = 'none';\n        \n        // 开