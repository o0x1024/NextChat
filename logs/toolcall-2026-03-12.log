{"file_path": "/Users/a1024/code/apptest/game.js", "content": "// 霓虹贪吃蛇游戏主逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        this.gameOverlay = document.getElementById('game-overlay');\n        this.overlayTitle = document.getElementById('overlay-title');\n        this.overlayMessage = document.getElementById('overlay-message');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodEaten = 0;\n        \n        // 游戏参数\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        this.gameSpeed = 150; // 初始速度（毫秒）\n        \n        // 蛇相关\n        this.snake = [];\n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 食物相关\n        this.food = null;\n        \n        // 道具相关\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 游戏循环\n        this.gameLoop = null;\n        this.lastUpdate = 0;\n        \n        // 初始化\n        this.init();\n    }\n    \n    init() {\n        // 设置Canvas尺寸\n        this.resizeCanvas();\n        window.addEventListener('resize', () => this.resizeCanvas());\n        \n        // 初始化UI\n        this.updateUI();\n        \n        // 绑定事件\n        this.bindEvents();\n        \n        // 生成初始障碍物\n        this.generateObstacles();\n        \n        // 显示开始菜单\n        this.showMenu();\n    }\n    \n    resizeCanvas() {\n        const container = this.canvas.parentElement;\n        const containerWidth = container.clientWidth;\n        const containerHeight = container.clientHeight;\n        \n        // 保持宽高比\n        const aspectRatio = 800 / 600;\n        let width = containerWidth;\n        let height = width / aspectRatio;\n        \n        if (height > containerHeight) {\n            height = containerHeight;\n            width = height * aspectRatio;\n        }\n        \n        this.canvas.style.width = width + 'px';\n        this.canvas.style.height = height + 'px';\n    }\n    \n    bindEvents() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => this.handleKeyDown(e));\n        \n        // 按钮控制\n        document.getElementById('start-btn').addEventListener('click', () => this.startGame());\n        document.getElementById('restart-btn').addEventListener('click', () => this.restartGame());\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => this.changeDirection(0, -1));\n        document.getElementById('down-btn').addEventListener('click', () => this.changeDirection(0, 1));\n        document.getElementById('left-btn').addEventListener('click', () => this.changeDirection(-1, 0));\n        document.getElementById('right-btn').addEventListener('click', () => this.changeDirection(1, 0));\n        \n        // 设置按钮\n        document.getElementById('settings-btn').addEventListener('click', () => this.showSettings());\n        document.getElementById('sound-btn').addEventListener('click', () => this.toggleSound());\n    }\n    \n    handleKeyDown(e) {\n        if (this.gameState === 'menu' && e.code === 'Space') {\n            this.startGame();\n            return;\n        }\n        \n        if (this.gameState !== 'playing') return;\n        \n        switch(e.key) {\n            case 'ArrowUp':\n            case 'w':\n            case 'W':\n                if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: -1 };\n                break;\n            case 'ArrowDown':\n            case 's':\n            case 'S':\n                if (this.snakeDirection.y === 0) this.nextDirection = { x: 0, y: 1 };\n                break;\n            case 'ArrowLeft':\n            case 'a':\n            case 'A':\n                if (this.snakeDirection.x === 0) this.nextDirection = { x: -1, y: 0 };\n                break;\n            case 'ArrowRight':\n            case 'd':\n            case 'D':\n                if (this.snakeDirection.x === 0) this.nextDirection = { x: 1, y: 0 };\n                break;\n            case 'Escape':\n                this.togglePause();\n                break;\n        }\n    }\n    \n    changeDirection(x, y) {\n        if (this.gameState !== 'playing') return;\n        if (this.snakeDirection.x === -x && this.snakeDirection.y === -y) return; // 不能直接反向\n        this.nextDirection = { x, y };\n    }\n    \n    startGame() {\n        this.gameState = 'playing';\n        this.score = 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodEaten = 0;\n        \n        // 初始化蛇\n        this.snake = [\n            { x: Math.floor(this.gridWidth / 2), y: Math.floor(this.gridHeight / 2) },\n            { x: Math.floor(this.gridWidth / 2) - 1, y: Math.floor(this.gridHeight / 2) },\n            { x: Math.floor(this.gridWidth / 2) - 2, y: Math.floor(this.gridHeight / 2) }\n        ];\n        \n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 清空道具\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 隐藏菜单\n        this.gameOverlay.style.display = 'none';\n        \n        // 开始游戏循环\n        this.startGameLoop();\n        \n        this.updateUI();\n    }\n    \n    restartGame() {\n        this.stopGameLoop();\n        this.startGame();\n    }\n    \n    togglePause() {\n        if (this.gameState === 'playing') {\n            this.gameState = 'paused';\n            this.showPauseMenu();\n        } else if (this.gameState === 'paused') {\n            this.gameState = 'playing';\n            this.gameOverlay.style.display = 'none';\n            this.startGameLoop();\n        }\n    }\n    \n    startGameLoop() {\n        if (this.gameLoop) clearInterval(this.gameLoop);\n        \n        this.gameLoop = setInterval(() => {\n            this.update();\n            this.draw();\n        }, this.getCurrentSpeed());\n    }\n    \n    stopGameLoop() {\n        if (this.gameLoop) {\n            clearInterval(this.gameLoop);\n            this.gameLoop = null;\n        }\n    }\n    \n    getCurrentSpeed() {\n        let speed = this.gameSpeed;\n        \n        // 速度加成\n        if (this.activePowerups.speedBoost.active) {\n            speed *= 0.5; // 加速50%\n        }\n        \n        // 每吃5个食物速度提升10%\n        speed *= (1 - (Math.floor(this.foodEaten / 5) * 0.1));\n        \n        return Math.max(speed, 50); // 最快50ms\n    }\n    \n    update() {\n        const currentTime = Date.now();\n        if (currentTime - this.lastUpdate < this.getCurrentSpeed()) return;\n        this.lastUpdate = currentTime;\n        \n        // 更新方向\n        this.snakeDirection = { ...this.nextDirection };\n        \n        // 计算新蛇头位置\n        let newHead = {\n            x: this.snake[0].x + this.snakeDirection.x,\n            y: this.snake[0].y + this.snakeDirection.y\n        };\n        \n        // 穿墙处理\n        if (this.activePowerups.wallPass.active) {\n            if (newHead.x < 0) newHead.x = this.gridWidth - 1;\n            if (newHead.x >= this.gridWidth) newHead.x = 0;\n            if (newHead.y < 0) newHead.y = this.gridHeight - 1;\n            if