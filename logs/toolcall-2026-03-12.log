{"content": "// 霓虹贪吃蛇游戏 - 主逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        this.scoreElement = document.getElementById('score');\n        this.highScoreElement = document.getElementById('high-score');\n        this.speedElement = document.getElementById('speed');\n        this.livesElement = document.getElementById('lives');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameOver\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speedMultiplier = 1.0;\n        this.foodCount = 0;\n        \n        // 游戏参数\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        this.gameSpeed = 150; // 初始速度（毫秒）\n        \n        // 蛇相关\n        this.snake = [];\n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 食物\n        this.food = null;\n        \n        // 道具\n        this.powerUps = [];\n        this.activePowerUps = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 游戏循环\n        this.gameLoop = null;\n        this.lastUpdateTime = 0;\n        \n        // 初始化\n        this.init();\n    }\n    \n    init() {\n        // 设置高分\n        this.highScoreElement.textContent = this.highScore;\n        \n        // 绑定事件\n        this.bindEvents();\n        \n        // 初始化游戏\n        this.resetGame();\n        \n        // 开始游戏循环\n        this.startGameLoop();\n    }\n    \n    bindEvents() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            this.handleKeyPress(e);\n        });\n        \n        // 按钮控制\n        document.getElementById('start-btn').addEventListener('click', () => {\n            this.startGame();\n        });\n        \n        document.getElementById('restart-btn').addEventListener('click', () => {\n            this.resetGame();\n            this.startGame();\n        });\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => {\n            this.changeDirection(0, -1);\n        });\n        \n        document.getElementById('down-btn').addEventListener('click', () => {\n            this.changeDirection(0, 1);\n        });\n        \n        document.getElementById('left-btn').addEventListener('click', () => {\n            this.changeDirection(-1, 0);\n        });\n        \n        document.getElementById('right-btn').addEventListener('click', () => {\n            this.changeDirection(1, 0);\n        });\n        \n        // 设置按钮\n        document.getElementById('settings-btn').addEventListener('click', () => {\n            this.togglePause();\n        });\n        \n        document.getElementById('sound-btn').addEventListener('click', () => {\n            this.toggleSound();\n        });\n    }\n    \n    handleKeyPress(e) {\n        switch(e.key) {\n            case ' ':\n            case 'Spacebar':\n                if (this.gameState === 'menu' || this.gameState === 'gameOver') {\n                    this.startGame();\n                } else if (this.gameState === 'playing') {\n                    this.togglePause();\n                }\n                break;\n                \n            case 'ArrowUp':\n            case 'w':\n            case 'W':\n                this.changeDirection(0, -1);\n                break;\n                \n            case 'ArrowDown':\n            case 's':\n            case 'S':\n                this.changeDirection(0, 1);\n                break;\n                \n            case 'ArrowLeft':\n            case 'a':\n            case 'A':\n                this.changeDirection(-1, 0);\n                break;\n                \n            case 'ArrowRight':\n            case 'd':\n            case 'D':\n                this.changeDirection(1, 0);\n                break;\n                \n            case 'Escape':\n                this.togglePause();\n                break;\n        }\n    }\n    \n    changeDirection(x, y) {\n        // 防止直接反向移动\n        if (this.gameState !== 'playing') return;\n        \n        if (x !== -this.snakeDirection.x || y !== -this.snakeDirection.y) {\n            this.nextDirection = { x, y };\n        }\n    }\n    \n    startGame() {\n        if (this.gameState === 'menu' || this.gameState === 'gameOver') {\n            this.gameState = 'playing';\n            this.hideOverlay();\n            this.resetGame();\n        }\n    }\n    \n    resetGame() {\n        // 重置蛇\n        const startX = Math.floor(this.gridWidth / 2);\n        const startY = Math.floor(this.gridHeight / 2);\n        this.snake = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 重置方向\n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 重置分数和状态\n        this.score = 0;\n        this.foodCount = 0;\n        this.speedMultiplier = 1.0;\n        this.lives = 2;\n        this.updateUI();\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 清空道具\n        this.powerUps = [];\n        this.resetPowerUps();\n    }\n    \n    generateFood() {\n        let food;\n        let validPosition = false;\n        \n        while (!validPosition) {\n            food = {\n                x: Math.floor(Math.random() * this.gridWidth),\n                y: Math.floor(Math.random() * this.gridHeight)\n