{"file_path": "/Users/a1024/code/apptest/game.js", "content": "// 霓虹贪吃蛇游戏核心逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        this.scoreElement = document.getElementById('score');\n        this.highScoreElement = document.getElementById('high-score');\n        this.speedElement = document.getElementById('speed');\n        this.livesElement = document.getElementById('lives');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.speedMultiplier = 1.0;\n        \n        // 游戏参数\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        this.gameSpeed = 150; // 初始速度（毫秒）\n        \n        // 蛇\n        this.snake = [];\n        this.snakeDirection = 'right';\n        this.nextDirection = 'right';\n        \n        // 食物\n        this.food = { x: 0, y: 0 };\n        \n        // 道具\n        this.powerUps = [];\n        this.activePowerUps = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 动画\n        this.particles = [];\n        this.trailEffects = [];\n        \n        // 初始化\n        this.init();\n        this.setupEventListeners();\n        this.updateUI();\n        this.draw();\n    }\n    \n    init() {\n        // 初始化蛇\n        const startX = Math.floor(this.gridWidth / 4);\n        const startY = Math.floor(this.gridHeight / 2);\n        this.snake = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        this.highScoreElement.textContent = this.highScore;\n    }\n    \n    generateFood() {\n        let foodPlaced = false;\n        while (!foodPlaced) {\n            this.food.x = Math.floor(Math.random() * this.gridWidth);\n            this.food.y = Math.floor(Math.random() * this.gridHeight);\n            \n            // 检查是否在蛇身上\n            const onSnake = this.snake.some(segment => \n                segment.x === this.food.x && segment.y === this.food.y);\n            \n            // 检查是否在障碍物上\n            const onObstacle = this.obstacles.some(obstacle =>\n                obstacle.x === this.food.x && obstacle.y === this.food.y);\n            \n            if (!onSnake && !onObstacle) {\n                foodPlaced = true;\n            }\n        }\n    }\n    \n    generateObstacles() {\n        this.obstacles = [];\n        const obstacleCount = 5 + Math.floor(Math.random() * 4); // 5-8个障碍物\n        \n        for (let i = 0; i < obstacleCount; i++) {\n            let obstaclePlaced = false;\n            while (!obstaclePlaced) {\n                const obstacle = {\n                    x: Math.floor(Math.random() * this.gridWidth),\n                    y: Math.floor(Math.random() * this.gridHeight)\n                };\n                \n                // 检查是否在蛇初始位置附近\n                const nearSnake = this.snake.some(segment =>\n                    Math.abs(segment.x - obstacle.x) < 3 && Math.abs(segment.y - obstacle.y) < 3);\n                \n                // 检查是否在食物位置\n                const onFood = obstacle.x === this.food.x && obstacle.y === this.food.y;\n                \n                // 检查是否与其他障碍物重叠\n                const onOtherObstacle = this.obstacles.some(o =>\n                    o.x === obstacle.x && o.y === obstacle.y);\n                \n                if (!nearSnake && !onFood && !onOtherObstacle) {\n                    this.obstacles.push(obstacle);\n                    obstaclePlaced = true;\n                }\n            }\n        }\n    }\n    \n    generatePowerUp() {\n        if (this.powerUps.length >= 2) return; // 最多2个道具\n        \n        const powerUpTypes = ['speedBoost', 'shield', 'wallPass'];\n        const type = powerUpTypes[Math.floor(Math.random() * powerUpTypes.length)];\n        \n        let powerUpPlaced = false;\n        while (!powerUpPlaced) {\n            const powerUp = {\n                x: Math.floor(Math.random() * this.gridWidth),\n                y: Math.floor(Math.random() * this.gridHeight),\n                type: type,\n                timer: 15 * 1000 // 15秒后消失\n            };\n            \n            // 检查位置是否有效\n            const onSnake = this.snake.some(segment =>\n                segment.x === powerUp.x && segment.y === powerUp.y);\n            const onFood = powerUp.x === this.food.x && powerUp.y === this.food.y;\n            const onObstacle = this.obstacles.some(obstacle =>\n                obstacle.x === powerUp.x && obstacle.y === powerUp.y);\n            const onOtherPowerUp = this.powerUps.some(p =>\n                p.x === powerUp.x && p.y === powerUp.y);\n            \n            if (!onSnake && !onFood && !onObstacle && !onOtherPowerUp) {\n                this.powerUps.push(powerUp);\n                powerUpPlaced = true;\n            }\n        }\n    }\n    \n    update() {\n        if (this.gameState !== 'playing') return;\n        \n        // 更新蛇方向\n        this.snakeDirection = this.nextDirection;\n        \n        // 计算新蛇头位置\n        const head = { ...this.snake[0] };\n        switch (this.snakeDirection) {\n            case 'up': head.y--; break;\n            case 'down': head.y++; break;\n            case 'left': head.x--; break;\n            case 'right': head.x++; break;\n        }\n        \n        // 穿墙效果\n        if (this.activePowerUps.wallPass.active) {\n            if (head.x < 0) head.x = this.gridWidth - 1;\n            if (head.x >= this.gridWidth) head.x = 0;\n            if (head.y < 0) head.y = this.gridHeight - 1;\n            if (head.y >= this.gridHeight) head.y = 0;\n        }\n        \n        // 检查碰撞\n        if (!this.checkCollision(head)) {\n            // 添加新蛇头\n            this.snake.unshift(head);\n            \n            // 检查是否吃到食物\n            if (head.x === this.food.x && head.y === this.food.y) {\n                this.score += Math.floor(10 * this.speedMultiplier);\n                this.generateFood();\n                \n                // 30%概率生成道具\n                if (Math.random() < 0.3) {\n                    this.generatePowerUp();\n                }\n                \n                // 每吃5个食物速度提升10%\n                if (this.score % 50 === 0) {\n                    this.speedMultiplier = Math.min(2.0, this.speedMultiplier + 0.1);\n                    this.speedElement.textContent = this.speedMultiplier.toFixed(1) + 'x';\n                }\n                \n                // 创建食物收集特效\n                this.createParticles(this.food.x, this.food.y, '#00ff99');\n            } else {\n                // 没吃到食物，移除蛇尾\n                this.snake.pop();\n            }\n            \n            // 检查是否吃到道具\n            const powerUpIndex = this.powerUps.findIndex(p =>\n                p.x === head.x && p.y === head.y);\n            if (powerUpIndex !== -1) {\n                const powerUp = this.powerUps[powerUpIndex];\n                this.activatePowerUp(powerUp.type);\n                this.powerUps.splice(powerUpIndex, 1);\n                \n                // 创建道具收集特效\n                this.createParticles(head.x, head.y, '#ff00ff');\n            }\n        } else {\n            // 碰撞发生\n            if (this.activePowerUps.shield.active) {\n                // 护盾保护，不死亡\n                this.snake.unshift(head);\n                this.snake.