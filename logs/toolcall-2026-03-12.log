{"file_path": "/Users/a1024/code/apptest/game.js", "content": "// 霓虹贪吃蛇游戏主逻辑\nclass NeonSnakeGame {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodCount = 0;\n        \n        // 游戏配置\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        \n        // 蛇的初始状态\n        this.snake = [];\n        this.snakeDirection = { x: 1, y: 0 };\n        this.nextDirection = { x: 1, y: 0 };\n        \n        // 食物\n        this.food = null;\n        \n        // 道具\n        this.powerUps = [];\n        this.activePowerUps = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 游戏循环\n        this.lastUpdateTime = 0;\n        this.updateInterval = 150; // 毫秒\n        \n        // 初始化\n        this.init();\n        this.setupEventListeners();\n        this.updateUI();\n        this.gameLoop();\n    }\n    \n    init() {\n        // 初始化蛇\n        const startX = Math.floor(this.gridWidth / 2);\n        const startY = Math.floor(this.gridHeight / 2);\n        this.snake = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 生成第一个食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        document.getElementById('high-score').textContent = this.highScore;\n    }\n    \n    setupEventListeners() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            switch(e.key) {\n                case 'ArrowUp':\n                case 'w':\n                case 'W':\n                    if (this.snakeDirection.y === 0) {\n                        this.nextDirection = { x: 0, y: -1 };\n                    }\n                    break;\n                case 'ArrowDown':\n                case 's':\n                case 'S':\n                    if (this.snakeDirection.y === 0) {\n                        this.nextDirection = { x: 0, y: 1 };\n                    }\n                    break;\n                case 'ArrowLeft':\n                case 'a':\n                case 'A':\n                    if (this.snakeDirection.x === 0) {\n                        this.nextDirection = { x: -1, y: 0 };\n                    }\n                    break;\n                case 'ArrowRight':\n                case 'd':\n                case 'D':\n                    if (this.snakeDirection.x === 0) {\n                        this.nextDirection = { x: 1, y: 0 };\n                    }\n                    break;\n                case ' ':\n                    if (this.gameState === 'menu') {\n                        this.startGame();\n                    } else if (this.gameState === 'gameover') {\n                        this.restartGame();\n                    }\n                    break;\n                case 'Escape':\n                    this.togglePause();\n                    break;\n            }\n        });\n        \n        // 按钮事件\n        document.getElementById('start-btn').addEventListener('click', () => this.startGame());\n        document.getElementById('restart-btn').addEventListener('click', () => this.restartGame());\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => {\n            if (this.snakeDirection.y === 0) {\n                this.nextDirection = { x: 0, y: -1 };\n            }\n        });\n        document.getElementById('down-btn').addEventListener('click', () => {\n            if (this.snakeDirection.y === 0) {\n                this.nextDirection = { x: 0, y: 1 };\n            }\n        });\n        document.getElementById('left-btn').addEventListener('click', () => {\n            if (this.snakeDirection.x === 0) {\n                this.nextDirection = { x: -1, y: 0 };\n            }\n        });\n        document.getElementById('right-btn').addEventListener('click', () => {\n            if (this.snakeDirection.x === 0) {\n                this.nextDirection = { x: 1, y: 0 };\n            }\n        });\n        \n        // 窗口大小调整\n        window.addEventListener('resize', () => this.handleResize());\n    }\n    \n    startGame() {\n        if (this.gameState === 'menu' || this.gameState === 'gameover') {\n            this.gameState = 'playing';\n            this.score = 0;\n            this.lives = 2;\n            this.speed = 1.0;\n            this.foodCount = 0;\n            this.init();\n            this.updateUI();\n        }\n    }\n    \n    restartGame() {\n        this.gameState = 'playing';\n        this.score = 0;\n        this.lives = 2;\n        this.speed = 1.0;\n        this.foodCount = 0;\n        this.init();\n        this.updateUI();\n    }\n    \n    togglePause() {\n        if (this.gameState === 'playing') {\n            this.gameState = 'paused';\n        } else if (this.gameState === 'paused') {\n            this.gameState = 'playing';\n        }\n        this.updateUI();\n    }\n    \n    update(currentTime) {\n        if (this.gameState !== 'playing') return;\n        \n        // 控制更新频率\n        if (currentTime - this.lastUpdateTime < this.updateInterval / this.speed) {\n            return;\n        }\n        this.lastUpdateTime = currentTime;\n        \n        // 更新方向\n        this.snakeDirection = { ...this.nextDirection };\n        \n        // 移动蛇头\n        const head = { ...this.snake[0] };\n        head.x += this.snakeDirection.x;\n        head.y += this.snakeDirection.y;\n        \n        // 检查穿墙\n        if (this.activePowerUps.wallPass.active) {\n            if (head.x < 0) head.x = this.gridWidth - 1;\n            if (head.x >= this.gridWidth) head.x = 0;\n            if (head.y < 0) head.y = this.gridHeight - 1;\n            if (head.y >= this.gridHeight) head.y = 0;\n        }\n        \n        // 检查碰撞\n        if (this.checkCollision(head)) {\n            this.handleCollision();\n            return;\n        }\n        \n        // 添加新头部\n        this.snake.unshift(head);\n        \n        // 检查是否吃到食物\n        if (this.food && head.x === this.food.x && head.y === this.food.y) {\n            this.handleFoodEaten();\n        } else {\n            // 没吃到食物就移除尾部\n            this.snake.pop();\n        }\n        \n        // 检查是否吃到道具\n        this.checkPowerUpCollision(head);\n        \n        // 更新道具计时器\n        this.updatePowerUpTimers();\n        \n        // 绘制\n        this.draw();\n    }\n    \n    checkCollision(position) {\n        // 检查墙壁碰撞（如果没有穿墙效果）\n        if (!this.activePowerUps.wallPass.active) {\n            if (position.x < 0 || position.x >= this.gridWidth ||\n                position.y < 0 || position.y >= this.gridHeight) {\n                return true;\n            }\n        }\n        \n        // 检查自身碰撞（如果没有护盾效果）\n        if (!this.activePowerUps.shield.active) {\n            for (let i = 1; i < this.snake.length; i++) {\n                if (position.x === this.snake[i].x && position.y === this.snake[i].y) {\n                    return true;\n                }\n            }\n        }\n        \n        // 检查障碍物碰撞（如果没有护盾效果）\n        if (!this.activePowerUps.shield.active) {\n            for (const obstacle of this.obstacles) {\n                if (position.x === obstacle.x && position.y === obstacle.y) {\n                    return true;\n                }\n            }\n        }\n