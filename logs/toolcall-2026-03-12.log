y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 生成食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        this.highScoreElement.textContent = this.highScore;\n    }\n    \n    generateFood() {\n        let foodPlaced = false;\n        while (!foodPlaced) {\n            this.food.x = Math.floor(Math.random() * this.gridWidth);\n            this.food.y = Math.floor(Math.random() * this.gridHeight);\n            \n            // 检查是否在蛇身上\n            const onSnake = this.snake.some(segment => \n                segment.x === this.food.x && segment.y === this.food.y);\n            \n            // 检查是否在障碍物上\n            const onObstacle = this.obstacles.some(obstacle =>\n                obstacle.x === this.food.x && obstacle.y === this.food.y);\n            \n            if (!onSnake && !onObstacle) {\n                foodPlaced = true;\n            }\n        }\n    }\n    \n    generateObstacles() {\n        this.obstacles = [];\n        const obstacleCount = 5 + Math.floor(Math.random() * 4); // 5-8个障碍物\n        \n        for (let i = 0; i < obstacleCount; i++) {\n            let obstaclePlaced = false;\n            while (!obstaclePlaced) {\n                const obstacle = {\n                    x: Math.floor(Math.random() * this.gridWidth),\n                    y: Math.floor(Math.random() * this.gridHeight)\n                };\n                \n                // 检查是否在蛇初始位置附近\n                const nearSnake = this.snake.some(segment =>\n                    Math.abs(segment.x - obstacle.x) < 3 && Math.abs(segment.y - obstacle.y) < 3);\n                \n                // 检查是否在食物位置\n                const onFood = obstacle.x === this.food.x && obstacle.y === this.food.y;\n                \n                // 检查是否与其他障碍物重叠\n                const onOtherObstacle = this.obstacles.some(o =>\n                    o.x === obstacle.x && o.y === obstacle.y);