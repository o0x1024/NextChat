{"file_path": "/Users/a1024/code/apptest/game.js", "content": "/* 霓虹贪吃蛇游戏主逻辑 */\n\nclass Game {\n    constructor() {\n        this.canvas = document.getElementById('game-canvas');\n        this.ctx = this.canvas.getContext('2d');\n        this.scoreElement = document.getElementById('score');\n        this.highScoreElement = document.getElementById('high-score');\n        this.speedElement = document.getElementById('speed');\n        this.livesElement = document.getElementById('lives');\n        this.gameOverlay = document.getElementById('game-overlay');\n        this.overlayTitle = document.getElementById('overlay-title');\n        this.overlayMessage = document.getElementById('overlay-message');\n        \n        // 游戏状态\n        this.gameState = 'menu'; // menu, playing, paused, gameover\n        this.score = 0;\n        this.highScore = localStorage.getItem('neonSnakeHighScore') || 0;\n        this.lives = 2;\n        this.speedMultiplier = 1.0;\n        this.foodCount = 0;\n        \n        // 游戏参数\n        this.gridSize = 20;\n        this.gridWidth = Math.floor(this.canvas.width / this.gridSize);\n        this.gridHeight = Math.floor(this.canvas.height / this.gridSize);\n        this.gameSpeed = 150; // 毫秒\n        this.baseSpeed = 150;\n        \n        // 蛇\n        this.snake = [];\n        this.snakeDirection = 'right';\n        this.nextDirection = 'right';\n        \n        // 食物\n        this.food = { x: 0, y: 0 };\n        \n        // 道具\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        // 障碍物\n        this.obstacles = [];\n        \n        // 初始化\n        this.init();\n        this.setupEventListeners();\n        this.updateUI();\n        this.draw();\n    }\n    \n    init() {\n        // 初始化蛇\n        const startX = Math.floor(this.gridWidth / 4);\n        const startY = Math.floor(this.gridHeight / 2);\n        this.snake = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        // 生成第一个食物\n        this.generateFood();\n        \n        // 生成障碍物\n        this.generateObstacles();\n        \n        // 更新高分显示\n        this.highScoreElement.textContent = this.highScore;\n    }\n    \n    setupEventListeners() {\n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            switch(e.key.toLowerCase()) {\n                case 'arrowup':\n                case 'w':\n                    if (this.snakeDirection !== 'down') this.nextDirection = 'up';\n                    break;\n                case 'arrowdown':\n                case 's':\n                    if (this.snakeDirection !== 'up') this.nextDirection = 'down';\n                    break;\n                case 'arrowleft':\n                case 'a':\n                    if (this.snakeDirection !== 'right') this.nextDirection = 'left';\n                    break;\n                case 'arrowright':\n                case 'd':\n                    if (this.snakeDirection !== 'left') this.nextDirection = 'right';\n                    break;\n                case ' ':\n                    if (this.gameState === 'menu' || this.gameState === 'gameover') {\n                        this.startGame();\n                    } else if (this.gameState === 'playing') {\n                        this.pauseGame();\n                    } else if (this.gameState === 'paused') {\n                        this.resumeGame();\n                    }\n                    break;\n                case 'escape':\n                    if (this.gameState === 'playing') {\n                        this.pauseGame();\n                    }\n                    break;\n            }\n        });\n        \n        // 按钮事件\n        document.getElementById('start-btn').addEventListener('click', () => this.startGame());\n        document.getElementById('restart-btn').addEventListener('click', () => this.restartGame());\n        \n        // 触摸控制\n        document.getElementById('up-btn').addEventListener('click', () => {\n            if (this.snakeDirection !== 'down') this.nextDirection = 'up';\n        });\n        document.getElementById('down-btn').addEventListener('click', () => {\n            if (this.snakeDirection !== 'up') this.nextDirection = 'down';\n        });\n        document.getElementById('left-btn').addEventListener('click', () => {\n            if (this.snakeDirection !== 'right') this.nextDirection = 'left';\n        });\n        document.getElementById('right-btn').addEventListener('click', () => {\n            if (this.snakeDirection !== 'left') this.nextDirection = 'right';\n        });\n    }\n    \n    startGame() {\n        this.gameState = 'playing';\n        this.gameOverlay.style.display = 'none';\n        this.gameLoop();\n    }\n    \n    pauseGame() {\n        this.gameState = 'paused';\n        this.overlayTitle.textContent = '游戏暂停';\n        this.overlayMessage.textContent = '按空格键继续游戏';\n        this.gameOverlay.style.display = 'flex';\n    }\n    \n    resumeGame() {\n        this.gameState = 'playing';\n        this.gameOverlay.style.display = 'none';\n    }\n    \n    restartGame() {\n        this.score = 0;\n        this.lives = 2;\n        this.speedMultiplier = 1.0;\n        this.foodCount = 0;\n        this.gameSpeed = this.baseSpeed;\n        this.snakeDirection = 'right';\n        this.nextDirection = 'right';\n        this.powerups = [];\n        this.activePowerups = {\n            speedBoost: { active: false, timer: 0 },\n            shield: { active: false, timer: 0 },\n            wallPass: { active: false, timer: 0 }\n        };\n        \n        this.init();\n        this.startGame();\n    }\n    \n    gameLoop() {\n        if (this.gameState !== 'playing') return;\n        \n        this.update();\n        this.draw();\n        \n        // 更新道具计时器\n        this.updatePowerupTimers();\n        \n        // 根据速度调整游戏循环\n        setTimeout(() => this.gameLoop(), this.gameSpeed);\n    }\n    \n    update() {\n        // 更新蛇的方向\n        this.snakeDirection = this.nextDirection;\n        \n        // 计算新蛇头位置\n        const head = { ...this.snake[0] };\n        switch(this.snakeDirection) {\n            case 'up': head.y--; break;\n            case 'down': head.y++; break;\n            case 'left': head.x--; break;\n            case 'right': head.x++; break;\n        }\n        \n        // 穿墙检查\n        if (!this.activePowerups.wallPass.active) {\n            if (head.x < 0 || head.x >= this.gridWidth || \n                head.y < 0 || head.y >= this.gridHeight) {\n                this.handleCollision();\n                return;\n            }\n        } else {\n            // 穿墙效果\n            if (head.x < 0) head.x = this.gridWidth - 1;\n            if (head.x >= this.gridWidth) head.x = 0;\n            if (head.y < 0) head.y = this.gridHeight - 1;\n            if (head.y >= this.gridHeight) head.y = 0;\n        }\n        \n        // 检查自身碰撞\n        if (!this.activePowerups.shield.active) {\n            for (let segment of this.snake) {\n                if (head.x === segment.x && head.y === segment.y) {\n                    this.handleCollision();\n                    return;\n                }\n            }\n        }\n        \n        // 检查障碍物碰撞\n        if (!this.activePowerups.shield.active) {\n            for (let obstacle of this.obstacles) {\n                if (head.x === obstacle.x && head.y === obstacle.y) {\n                    this.handleCollision();\n                    return;\n                }\n            }\n        }\n        \n        // 添加到蛇头\n        this.snake.unshift(head);\n        \n        // 检查食物\n        if (head.x === this.food.x && head.y === this.food.y) {\n            this.eatFood();\n        } else {\n            /