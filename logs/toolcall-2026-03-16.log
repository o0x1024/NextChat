  4	import { GAME_CONFIG } from '../utils/constants.js';
  5	
  6	export class Renderer {
  7	    constructor(canvas) {
  8	        this.canvas = canvas;
  9	        this.ctx = canvas.getContext('2d');
 10	        this.grid = null;
 11	        
 12	        // 调整画布尺寸
 13	        this.resize();
 14	    }
 15	
 16	    /**
 17	     * 调整画布尺寸
 18	     */
 19	    resize() {
 20	        const container = this.canvas.parentElement;
 21	        const size = Math.min(container.clientWidth, container.clientHeight);
 22	        
 23	        this.canvas.width = GAME_CONFIG.CANVAS_WIDTH;
 24	        this.canvas.height = GAME_CONFIG.CANVAS_HEIGHT;
 25	        
 26	        this.ctx.imageSmoothingEnabled = false;
 27	    }
 28	
 29	    /**
 30	     * 设置网格引用
 31	     */
 32	    setGrid(grid) {
 33	        this.grid = grid;
 34	    }
 35	
 36	    /**
 37	     * 清空画布
 38	     */
 39	    clear() {
 40	        const { ctx, canvas } = this;
 41	        ctx.fillStyle = GAME_CONFIG.COLORS.BACKGROUND;
 42	        ctx.fillRect(0, 0, canvas.width, canvas.height);
 43	    }
 44	
 45	    /**
 46	     * 绘制网格背景
 47	     */
 48	    drawGrid() {
 49	        const { ctx, grid } = this;
 50	        const { cellSize, COLORS } = GAME_CONFIG;
 51	
 52	        ctx.strokeStyle = COLORS.GRID_LINE;
 53	        ctx.lineWidth = 0.5;
 54	
 55	        // 绘制垂直线
 56	        for (let x = 0; x <= grid.cols; x++) {
 57	            ctx.beginPath();
 58	            ctx.moveTo(x * cellSize, 0);
 59	            ctx.lineTo(x * cellSize, grid.height);
 60	            ctx.stroke();
 61	        }
 62	
 63	        // 绘制水平线
 64	        for (let y = 0; y <= grid.rows; y++) {
 65	            ctx.beginPath();
 66	            ctx.moveTo(0, y * cellSize);
 67	            ctx.lineTo(grid.width, y * cellSize);
 68	            ctx.stroke();
 69	        }
 70	
 71	        // 绘制网格点
 72	        ctx.fillStyle = COLORS.GRID_DOT;
 73	        for (let x = 0; x < grid.cols; x++) {
 74	            for (let y = 0; y < grid.rows; y++) {
 75	                ctx.beginPath();
 76	                ctx.arc(
 77	                    x * cellSize + cellSize / 2,
 78	                    y * cellSize + cellSize / 2,
 79	                    1, 0, Math.PI * 2
 80	                );
 81	                ctx.fill();
 82	            }
 83	        }
 84	    }
 85	
 86	    /**
 87	     * 绘制蛇
 88	     */
 89	    drawSnake(snake) {
 90	        const { ctx, grid } = this;
 91	        const { cellSize, COLORS, GLOW_BLUR } = GAME_CONFIG;
 92	        const positions = snake.positions;
 93	
 94	        if (positions.length === 0) return;
 95	
 96	        // 绘制蛇身（从尾部到头部）
 97	        for (let i = positions.length - 1; i >= 0; i--) {
 98	            const pos = positions[i];
 99	            const pixel = grid.toPixel(pos.x, pos.y);
100	            const isHead = i === 0;
101	            
102	            // 计算渐变色
103	            const gradientPos = i / positions.length;
104	            const colorIndex = Math.floor(gradientPos * (COLORS.SNAKE_BODY_GRADIENT.length - 1));
105	            const color = isHead ? COLORS.SNAKE_HEAD : COLORS.SNAKE_BODY_GRADIENT[colorIndex] || COLORS.SNAKE_HEAD;
106	
107	            // 发光效果
108	            ctx.save();
109	            ctx.shadowBlur = isHead ? GLOW_BLUR * 1.5 : GLOW_BLUR;
110	            ctx.shadowColor = color;
111	            
112	            // 绘制圆角矩形
113	            const padding = 2;
114	            const size = cellSize - padding * 2;
115	            const radius = isHead ? size / 2 : size / 3;
116	
117	            this.drawRoundedRect(
118	                pixel.x - size / 2,
119	                pixel.y - size / 2,
120	                size, size,
121	                radius
122	            );
123	
124	            // 填充
125	            ctx.fillStyle = color;
126	            ctx.globalCompositeOperation = 'lighter';
127	            ctx.fill();
128	            
129	            // 蛇头眼睛
130	            if (isHead) {
131	                ctx.fillStyle = '#ffffff';
132	                const eyeSize = size / 5;
133	                const eyeOffset = size / 4;
134	                
135	                // 根据方向绘制眼睛
136	                const { direction } = snake;
137	                if (direction.x === 1) { // 向右
138	                    ctx.beginPath();
139	                    ctx.arc(pixel.x + eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
140	                    ctx.arc(pixel.x + eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
141	                    ctx.fill();
142	                } else if (direction.x === -1) { // 向左
143	                    ctx.beginPath();
144	                    ctx.arc(pixel.x - eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
145	                    ctx.arc(pixel.x - eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
146	                    ctx.fill();
147	                } else if (direction.y === -1) { // 向上
148	                    ctx.beginPath();
149	                    ctx.arc(pixel.x - eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
150	                    ctx.arc(pixel.x + eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
151	                    ctx.fill();
152	                } else { // 向下
153	                    ctx.beginPath();
154	                    ctx.arc(pixel.x - eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
155	                    ctx.arc(pixel.x + eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
156	                    ctx.fill();
157	                }
158	            }
159	            
160	            ctx.restore();
161	        }
162	    }
163	
164	    /**
165	     * 绘制食物
166	     */
167	    drawFood(food) {
168	        if (!food.active) return;
169	
170	        const { ctx, grid } = this;
171	        const { cellSize, GLOW_BLUR } = GAME_CONFIG;
172	        const pixel = grid.toPixel(food.position.x, food.position.y);
173	        const scale = food.getScale();
174	        const baseSize = cellSize - 6;
175	        const size = baseSize * scale;
176	
177	        ctx.save();
178	        
179	        // 发光效果
180	        ctx.shadowBlur = GLOW_BLUR * 2;
181	        ctx.shadowColor = food.getGlowColor();
182	        ctx.globalCompositeOperation = 'lighter';
183	
184	        // 绘制菱形食物
185	        ctx.fillStyle = food.getColor();
186	        ctx.beginPath();
187	        ctx.moveTo(pixel.x, pixel.y - size / 2);
188	        ctx.lineTo(pixel.x + size / 2, pixel.y);
189	        ctx.lineTo(pixel.x, pixel.y + size / 2);
190	        ctx.lineTo(pixel.x - size / 2, pixel.y);
191	        ctx.closePath();
192	        ctx.fill();
193	
194	        // 内部高光
195	        ctx.fillStyle = '#ffffff';
196	        ctx.globalAlpha = 0.3;
197	        ctx.beginPath();
198	        ctx.arc(pixel.x, pixel.y, size / 4, 0, Math.PI * 2);
199	        ctx.fill();
200	
201	        ctx.restore();
202	    }
203	
204	    /**
205	     * 绘制圆角矩形
206	     */
207	    drawRoundedRect(x, y, width, height, radius) {
208	        const { ctx } = this;
209	        ctx.beginPath();
210	        ctx.moveTo(x + radius, y);
211	        ctx.lineTo(x + width - radius, y);
212	        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
213	        ctx.lineTo(x + width, y + height - radius);
214	        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
215	        ctx.lineTo(x + radius, y + height);
216	        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
217	        ctx.lineTo(x, y + radius);
218	        ctx.quadraticCurveTo(x, y, x + radius, y);
219	        ctx.closePath();
220	    }
221	
222	    /**
223	     * 绘制粒子
224	     */
225	    drawParticles(particleSystem) {
226	        particleSystem.render(this.ctx);
227	    }
228	}


