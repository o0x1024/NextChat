 70	    margin-right: 8px;
 71	    text-transform: uppercase;
 72	    letter-spacing: 1px;
 73	}
 74	
 75	#score, #high-score {
 76	    color: #fff;
 77	    font-size: 18px;
 78	    font-weight: bold;
 79	    text-shadow: 0 0 10px var(--neon-cyan);
 80	}
 81	
 82	/* 屏幕层 */
 83	.screen {
 84	    position: absolute;
 85	    top: 0;
 86	    left: 0;
 87	    right: 0;
 88	    bottom: 0;
 89	    display: flex;
 90	    flex-direction: column;
 91	    justify-content: center;
 92	    align-items: center;
 93	    background: rgba(10, 10, 21, 0.95);
 94	    z-index: 100;
 95	    transition: opacity 0.3s ease;
 96	}
 97	
 98	.screen.hidden {
 99	    opacity: 0;
100	    pointer-events: none;
101	}
102	
103	.title {
104	    font-size: 48px;
105	    font-weight: 900;
106	    color: #fff;
107	    text-shadow: 
108	        0 0 10px var(--neon-cyan),
109	        0 0 20px var(--neon-pink),
110	        0 0 40px var(--neon-purple);
111	    margin-bottom: 10px;
112	    letter-spacing: 4px;
113	}
114	
115	.subtitle {
116	    font-size: 18px;
117	    color: var(--neon-pink);
118	    margin-bottom: 40px;
119	    letter-spacing: 8px;
120	    text-transform: uppercase;
121	}
122	
123	.final-score {
124	    font-size: 24px;
125	    color: var(--neon-green);
126	    margin-bottom: 30px;
127	}
128	
129	/* 按钮 */
130	.btn {
131	    padding: 15px 50px;
132	    font-size: 18px;
133	    font-weight: bold;
134	    color: var(--bg-dark);
135	    background: linear-gradient(135deg, var(--neon-cyan), var(--neon-green));
136	    border: none;
137	    border-radius: 30px;
138	    cursor: pointer;
139	    transition: all 0.3s ease;
140	    text-transform: uppercase;
141	    letter-spacing: 2px;
142	    box-shadow: 
143	        0 0 20px rgba(0, 255, 255, 0.5),
144	        0 0 40px rgba(0, 255, 255, 0.2);
145	}
146	
147	.btn:hover {
148	    transform: scale(1.05);
149	    box-shadow: 
150	        0 0 30px var(--neon-cyan),
151	        0 0 60px rgba(0, 255, 255, 0.4);
152	}
153	
154	.btn:active {
155	    transform: scale(0.98);
156	}
157	
158	.hint {
159	    margin-top: 30px;
160	    color: rgba(255, 255, 255, 0.5);
161	    font-size: 14px;
162	}
163	
164	/* 触摸控制 - 移动端 */
165	#touch-controls {
166	    position: absolute;
167	    bottom: 20px;
168	    left: 50%;
169	    transform: translateX(-50%);
170	    display: none;
171	    flex-direction: column;
172	    align-items: center;
173	    gap: 8px;
174	    z-index: 50;
175	}
176	
177	.touch-row {
178	    display: flex;
179	    gap: 8px;
180	}
181	
182	.touch-btn {
183	    width: 60px;
184	    height: 60px;
185	    font-size: 24px;
186	    background: rgba(0, 255, 255, 0.15);
187	    border: 2px solid var(--neon-cyan);
188	    border-radius: 12px;
189	    color: var(--neon-cyan);
190	    cursor: pointer;
191	    transition: all 0.15s ease;
192	    display: flex;
193	    justify-content: center;
194	    align-items: center;
195	}
196	
197	.touch-btn:active {
198	    background: rgba(0, 255, 255, 0.4);
199	    box-shadow: 0 0 20px var(--neon-cyan);
200	    transform: scale(0.95);
201	}
202	
203	/* 移动端显示触摸控制 */
204	@media (max-width: 768px) {
205	    #touch-controls {
206	        display: flex;
207	    }
208	    
209	    .hint {
210	        display: none;
211	    }
212	    
213	    .title {
214	        font-size: 32px;
215	    }
216	}
217	
218	/* 动画效果 */
219	@keyframes pulse {
220	    0%, 100% { opacity: 1; }
221	    50% { opacity: 0.7; }
222	}
223	
224	#score-display, #high-score-display {
225	    animation: pulse 2s ease-in-out infinite;
226	}


