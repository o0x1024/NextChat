178	    /**
179	     * 开始游戏循环
180	     */
181	    startGameLoop() {
182	        this.lastUpdateTime = performance.now();
183	        const loop = (currentTime) => {
184	            if (this.state === GAME_STATE.PLAYING) {
185	                const deltaTime = currentTime - this.lastUpdateTime;
186	                const speed = this.snake.getSpeed();
187	
188	                if (deltaTime >= speed) {
