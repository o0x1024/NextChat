import { DIRECTIONS } from '../utils/constants.js';

export class InputManager {
    constructor() {
        this.keyHandlers = [];
        this.touchHandlers = [];
        this.setupKeyboard();
        this.setupTouch();
    }

    /**
     * 注册键盘处理器
     */
    onKey(callback) {
        this.keyHandlers.push(callback);
    }

    /**
     * 注册触摸处理器
     */
    onTouch(callback) {
        this.touchHandlers.push(callback);
    }

    /**
     * 设置键盘事件
     */
    setupKeyboard() {
        document.addEventListener('keydown', (e) => {
            // 防止方向键和空格滚动页面
            if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'Space', 'w', 'a', 's', 'd', 'W', 'A', 'S', 'D'].includes(e.key)) {
                e.preventDefault();
            }

            let direction = null;

            switch (e.key) {
                case 'ArrowUp':
                case 'w':
                case 'W':
                    direction = DIRECTIONS.UP;
                    break;
                case 'ArrowDown':
                case 's':
                case 'S':
                    direction = DIRECTIONS.DOWN;
                    break;
                case 'ArrowLeft':
                case 'a':
                case 'A':
                    direction = DIRECTIONS.LEFT;
                    break;
                case 'ArrowRight':
                case 'd':
                case 'D':
                    direction = DIRECTIONS.RIGHT;
                    break;
                case ' ':
                case 'Escape':
                case 'p':
                case 'P':
                    // 暂停功能由游戏状态机处理
                    this.keyHandlers.forEach(h => h({ type: 'pause', key: e.key }));
                    return;
            }

            if (direction) {
                this.keyHandlers.forEach(h => h({ type: 'direction', direction }));
            }
        });
    }

    /**
     * 设置触摸控制
     */
    setupTouch() {
        const directions = {
            'up-btn': DIRECTIONS.UP,
            'down-btn': DIRECTIONS.DOWN,
            'left-btn': DIRECTIONS.LEFT,
            'right-btn': DIRECTIONS.RIGHT,
        };

        Object.entries(directions).forEach(([id, direction]) => {
            const btn = document.getElementById(id);
            if (btn) {
                // 触摸事件
                btn.addEventListener('touchstart', (e) => {
                    e.preventDefault();
                    this.touchHandlers.forEach(h => h({ type: 'direction', direction }));
                }, { passive: false });

                // 鼠标事件（用于测试）
                btn.addEventListener('mousedown', (e) => {
                    e.preventDefault();
                    this.touchHandlers.forEach(h => h({ type: 'direction', direction }));
                });
            }
        });
    }

    /**
     * 移除所有事件监听
     */
    destroy() {
        this.keyHandlers = [];
        this.touchHandlers = [];
    }
}


