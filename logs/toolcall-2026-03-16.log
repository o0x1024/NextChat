/**
 * 网格系统 - 管理游戏区域坐标转换和边界
 */
import { GAME_CONFIG } from '../utils/constants.js';

export class Grid {
    constructor() {
        this.cellSize = GAME_CONFIG.GRID_SIZE;
        this.cols = GAME_CONFIG.GRID_COUNT;
        this.rows = GAME_CONFIG.GRID_COUNT;
        this.width = this.cols * this.cellSize;
        this.height = this.rows * this.cellSize;
    }

    /**
     * 将网格坐标转换为画布像素坐标
     */
    toPixel(gridX, gridY) {
        return {
            x: gridX * this.cellSize + this.cellSize / 2,
            y: gridY * this.cellSize + this.cellSize / 2
        };
    }

    /**
     * 将像素坐标转换为网格坐标
     */
    toGrid(pixelX, pixelY) {
        return {
            x: Math.floor(pixelX / this.cellSize),
            y: Math.floor(pixelY / this.cellSize)
        };
    }

    /**
     * 检查坐标是否在网格范围内
     */
    isValid(gridX, gridY) {
        return gridX >= 0 && gridX < this.cols &&
               gridY >= 0 && gridY < this.rows;
    }

    /**
     * 获取随机可用网格坐标（避开蛇身）
     */
    getRandomPosition(excludePositions = []) {
        let x, y, attempts = 0;
        const maxAttempts = this.cols * this.rows;
        
        do {
            x = Math.floor(Math.random() * this.cols);
            y = Math.floor(Math.random() * this.rows);
            attempts++;
            
            if (attempts >= maxAttempts) {
                break;
            }
        } while (this.isPositionOccupied(x, y, excludePositions));
        
        return { x, y };
    }

    /**
     * 检查指定位置是否被占用
     */
    isPositionOccupied(x, y, positions) {
        return positions.some(pos => pos.x === x && pos.y === y);
    }

    /**
     * 获取所有网格位置
     */
    getAllPositions() {
        const positions = [];
        for (let y = 0; y < this.rows; y++) {
            for (let x = 0; x < this.cols; x++) {
                positions.push({ x, y });
            }
        }
        return positions;
    }
}


