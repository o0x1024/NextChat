/**
 * 游戏模式系统 - 管理不同游戏模式
 */
import { GAME_CONFIG, GAME_MODE } from '../utils/constants.js';

export class GameMode {
    constructor(modeId = GAME_MODE.CLASSIC) {
        this.modeId = modeId;
        this.config = GAME_CONFIG.GAME_MODES[modeId.toUpperCase()] || GAME_CONFIG.GAME_MODES.CLASSIC;
        this.timeRemaining = this.config.timeLimit || 0;
        this.isActive = false;
    }

    /**
     * 获取模式名称
     */
    getName() {
        return this.config.name;
    }

    /**
     * 获取模式描述
     */
    getDescription() {
        return this.config.description;
    }

    /**
     * 获取障碍物数量
     */
    getObstacleCount() {
        return this.config.obstacleCount;
    }

    /**
     * 获取道具生成概率
     */
    getPowerUpSpawnChance() {
        return this.config.powerUpSpawnChance;
    }

    /**
     * 是否有时间限制
     */
    hasTimeLimit() {
        return this.config.hasTimeLimit;
    }

    /**
     * 获取时间限制（毫秒）
     */
    getTimeLimit() {
        return this.config.timeLimit;
    }

    /**
     * 是否有速度限制（无尽模式无限制）
     */
    hasSpeedLimit() {
        return !this.config.noSpeedLimit;
    }

    /**
     * 更新时间（用于限时模式）
     */
    updateTime(deltaTime) {
        if (this.hasTimeLimit() && this.isActive) {
            this.timeRemaining -= deltaTime;
            if (this.timeRemaining <= 0) {
                this.timeRemaining = 0;
                return true; // 时间到
            }
        }
        return false;
    }

    /**
     * 开始模式
     */
    start() {
        this.isActive = true;
        this.timeRemaining = this.config.timeLimit || 0;
    }

    /**
     * 停止模式
     */
    stop() {
        this.isActive = false;
    }

    /**
     * 获取剩余时间（秒）
     */
    getTimeRemainingSeconds() {
        return Math.ceil(this.timeRemaining / 1000);
    }

    /**
     * 获取速度调整（随着时间/分数调整难度）
     */
    getSpeedBonus(snakeLength) {
        if (!this.hasSpeedLimit()) {
            // 无尽模式：速度持续增加
            const bonus = Math.floor(snakeLength / 10) * 10;
            return -Math.min(bonus, 80); // 最多减少80ms
        }
        return 0;
    }
}

/**
 * 模式选择器
 */
export class GameModeManager {
    constructor() {
        this.modes = {
            [GAME_MODE.CLASSIC]: new GameMode(GAME_MODE.CLASSIC),
            [GAME_MODE.CHALLENGE]: new GameMode(GAME_MODE.CHALLENGE),
            [GAME_MODE.TIME_ATTACK]: new GameMode(GAME_MODE.TIME_ATTACK),
            [GAME_MODE.ENDLESS]: new GameMode(GAME_MODE.ENDLESS)
        };
        this.currentMode = this.modes[GAME_MODE.CLASSIC];
    }

    /**
     * 设置游戏模式
     */
    setMode(modeId) {
        if (this.modes[modeId]) {
            this.currentMode = this.modes[modeId];
            return true;
        }
        return false;
    }

    /**
     * 获取当前模式
     */
    getCurrentMode() {
        return this.currentMode;
    }

    /**
     * 获取所有可用模式
     */
    getAllModes() {
        return Object.values(this.modes);
    }

    /**
     * 开始当前模式
     */
    startMode() {
        this.currentMode.start();
    }

    /**
     * 停止当前模式
     */
    stopMode() {
        this.currentMode.stop();
    }

    /**
     * 获取模式列表（用于UI显示）
     */
    getModeList() {
        return [
            {
                id: GAME_MODE.CLASSIC,
                name: '经典模式',
                description: '经典贪吃蛇玩法，吃食物变长'
            },
            {
                id: GAME_MODE.CHALLENGE,
                name: '挑战模式',
                description: '有地形障碍，难度更高'
            },
            {
                id: GAME_MODE.TIME_ATTACK,
                name: '限时模式',
                description: '60秒内尽可能获得高分'
            },
            {
                id: GAME_MODE.ENDLESS,
                name: '无尽模式',
                description: '无限长度，速度越来越快'
            }
        ];
    }
}


