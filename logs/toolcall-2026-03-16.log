1	/**
  2	 * 粒子系统 - 用于食物特效和死亡效果
  3	 */
  4	import { GAME_CONFIG } from '../utils/constants.js';
  5	
  6	class Particle {
  7	    constructor() {
  8	        this.reset();
  9	    }
 10	
 11	    reset() {
 12	        this.x = 0;
 13	        this.y = 0;
 14	        this.vx = 0;
 15	        this.vy = 0;
 16	        this.life = 0;
 17	        this.maxLife = 0;
 18	        this.color = '#ffffff';
 19	        this.size = 0;
 20	        this.active = false;
 21	    }
 22	
 23	    init(x, y, color, speed, size, life) {
 24	        this.x = x;
 25	        this.y = y;
 26	        const angle = Math.random() * Math.PI * 2;
 27	        const velocity = Math.random() * speed;
 28	        this.vx = Math.cos(angle) * velocity;
 29	        this.vy = Math.sin(angle) * velocity;
 30	        this.life = life;
 31	        this.maxLife = life;
 32	        this.color = color;
 33	        this.size = size;
 34	        this.active = true;
 35	    }
 36	
 37	    update() {
 38	        if (!this.active) return;
 39	
 40	        this.x += this.vx;
 41	        this.y += this.vy;
 42	        this.life--;
 43	        
 44	        // 减速效果
 45	        this.vx *= 0.98;
 46	        this.vy *= 0.98;
 47	
 48	        if (this.life <= 0) {
 49	            this.active = false;
 50	        }
 51	    }
 52	
 53	    draw(ctx) {
 54	        if (!this.active) return;
 55	
 56	        const alpha = this.life / this.maxLife;
 57	        const currentSize = this.size * alpha;
 58	
 59	        ctx.save();
 60	        ctx.globalAlpha = alpha;
 61	        ctx.globalCompositeOperation = 'lighter';
 62	        ctx.fillStyle = this.color;
 63	        ctx.shadowBlur = 10;
 64	        ctx.shadowColor = this.color;
 65	        
 66	        ctx.beginPath();
 67	        ctx.arc(this.x, this.y, currentSize, 0, Math.PI * 2);
 68	        ctx.fill();
 69	        ctx.restore();
 70	    }
 71	}
 72	
 73	export class ParticleSystem {
 74	    constructor() {
 75	        this.particles = [];
 76	        this.maxParticles = 100;
 77	        
 78	        // 初始化粒子池
 79	        for (let i = 0; i < this.maxParticles; i++) {
 80	            this.particles.push(new Particle());
 81	        }
 82	    }
 83	
 84	    /**
 85	     * 发射粒子
 86	     */
 87	    emit(x, y, color, count = 20) {
 88	        const available = this.particles.filter(p => !p.active);
 89	        const toEmit = Math.min(count, available.length);
 90	        
 91	        for (let i = 0; i < toEmit; i++) {
 92	            const particle = available[i];
 93	            particle.init(
 94	                x, 
 95	                y, 
 96	                color,
 97	                3 + Math.random() * 3,  // 速度
 98	                3 + Math.random() * 3,  // 大小
 99	                30 + Math.random() * 20  // 生命周期
100	            );
101	        }
102	    }
103	
104	    /**
105	     * 发射食物吃掉特效
106	     */
107	    emitFoodEat(x, y) {
108	        const colors = ['#ff00ff', '#ff66ff', '#ff99ff', '#00ffff', '#00ccff'];
109	        const color = colors[Math.floor(Math.random() * colors.length)];
110	        this.emit(x, y, color, GAME_CONFIG.PARTICLE_COUNT);
111	    }
112	
113	    /**
114	     * 发射死亡特效
115	     */
116	    emitDeath(x, y) {
117	        const colors = ['#ff0000', '#ff6600', '#ff0066', '#ff3300'];
118	        for (let i = 0; i < 50; i++) {
119	            const color = colors[Math.floor(Math.random() * colors.length)];
120	            this.emit(x, y, color, 10);
121	        }
122	    }
123	
124	    /**
125	     * 更新所有粒子
126	     */
127	    update() {
128	        this.particles.forEach(p => p.update());
129	    }
130	
131	    /**
132	     * 渲染所有粒子
133	     */
134	    render(ctx) {
135	        this.particles.forEach(p => p.draw(ctx));
136	    }
137	
138	    /**
139	     * 清空所有粒子
140	     */
141	    clear() {
142	        this.particles.forEach(p => p.active = false);
143	    }
144	}


