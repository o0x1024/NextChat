{"file_path":"/Users/like/code/apptest/src/core/Game.js","new_string":"    /**\n     * 更新游戏状态\n     */\n    update() {\n        // 更新蛇\n        this.snake.update();\n\n        // 检查死亡\n        if (!this.snake.alive) {\n            this.gameOver();\n            return;\n        }\n\n        // 检查是否撞到障碍物\n        const head = this.snake.getHead();\n        if (this.obstacleManager.hasObstacle(head.x, head.y)) {\n            // 有护盾时可以穿过障碍物\n            if (!this.snake.hasShield) {\n                this.gameOver();\n                return;\n            }\n        }\n\n        // 检查吃到道具\n        if (this.powerUp.isActive() && this.snake.checkFood(this.powerUp.position)) {\n            // 吃到道具\n            this.score = this.snake.eatFood(this.powerUp);\n            this.updateScoreDisplay();\n\n            // 道具特效\n            const pixel = this.grid.toPixel(this.powerUp.position.x, this.powerUp.position.y);\n            const colors = {\n                'normal': '#ff00ff',\n                'speed': '#ffff00',\n                'shield': '#00ff00',\n                'growth': '#ff6600',\n                'slow': '#66ccff'\n            };\n            this.particles.emitFoodEat(pixel.x, pixel.y, colors[this.powerUp.type] || '#ff00ff');\n\n            // 应用特殊效果\n            if (this.powerUp.isSpecial()) {\n                this.powerUpManager.applyEffect(this.powerUp.type);\n                this.powerUpManager.setEffectDuration(\n                    this.powerUp.type,\n                    this.powerUp.config.duration\n                );\n            }\n\n            // 生成新道具\n            const occupiedPositions = [\n                ...this.snake.positions,\n                ...this.obstacleManager.getPositions()\n            ];\n            this.powerUp.generate(occupiedPositions);\n        }\n\n        // 更新道具动画\n        this.powerUp.update(16);\n\n        // 更新障碍物动画\n        this.obstacleManager.update();\n\n        // 更新粒子\n        this.particles.update();\n    }","old_string":"    /**\n     * 更新游戏状态\n     */\n    update() {\n        // 更新蛇\n        this.snake.update();\n\n        // 检查死亡\n        if (!this.snake.alive) {\n            this.gameOver();\n            return;\n        }\n\n        // 检查吃到食物\n        const foodPos = this.food.getPosition();\n        if (this.snake.checkFood(foodPos)) {\n            // 吃到食物\n            this.score = this.snake.eatFood();\n            this.updateScoreDisplay();\n\n            // 食物特效\n            const pixel = this.grid.toPixel(foodPos.x, foodPos.y);\n            this.particles.emitFoodEat(pixel.x, pixel.y);\n\n            // 生成新食物\n            this.food.generate(this.snake.positions);\n        }\n\n        // 更新食物动画\n        this.food.update();\n\n        // 更新粒子\n        this.particles.update();\n    }"}


