/**
 * 障碍物系统 - 管理地形障碍
 */
import { GAME_CONFIG } from '../utils/constants.js';

export class Obstacle {
    constructor(grid, x, y) {
        this.grid = grid;
        this.position = { x, y };
        this.active = true;
        this.animationPhase = Math.random() * Math.PI * 2;
    }

    /**
     * 检查指定位置是否有障碍物
     */
    isAt(x, y) {
        return this.active && this.position.x === x && this.position.y === y;
    }

    /**
     * 更新动画
     */
    update() {
        this.animationPhase += 0.05;
        if (this.animationPhase > Math.PI * 2) {
            this.animationPhase = 0;
        }
    }
}

export class ObstacleManager {
    constructor(grid) {
        this.grid = grid;
        this.obstacles = [];
    }

    /**
     * 初始化障碍物
     */
    initialize(excludePositions = [], count = 5) {
        this.obstacles = [];
        const maxAttempts = this.grid.cols * this.grid.rows;
        let attempts = 0;

        while (this.obstacles.length < count && attempts < maxAttempts) {
            const x = Math.floor(Math.random() * this.grid.cols);
            const y = Math.floor(Math.random() * this.grid.rows);

            // 检查是否与排除位置冲突
            const isOccupied = excludePositions.some(pos => pos.x === x && pos.y === y);

            // 检查是否与已有障碍物冲突
            const isDuplicate = this.obstacles.some(obs => obs.position.x === x && obs.position.y === y);

            // 排除边缘位置（给蛇留出空间）
            const isEdge = x === 0 || x === this.grid.cols - 1 ||
                          y === 0 || y === this.grid.rows - 1;

            if (!isOccupied && !isDuplicate && !isEdge) {
                this.obstacles.push(new Obstacle(this.grid, x, y));
            }

            attempts++;
        }
    }

    /**
     * 检查指定位置是否有障碍物
     */
    hasObstacle(x, y) {
        return this.obstacles.some(obs => obs.isAt(x, y));
    }

    /**
     * 获取所有障碍物位置
     */
    getPositions() {
        return this.obstacles.map(obs => obs.position);
    }

    /**
     * 更新所有障碍物
     */
    update() {
        this.obstacles.forEach(obs => obs.update());
    }

    /**
     * 清除所有障碍物
     */
    clear() {
        this.obstacles = [];
    }

    /**
     * 获取障碍物数量
     */
    count() {
        return this.obstacles.length;
    }
}


