/**
 * 道具系统 - 管理游戏中的特殊道具
 */
import { GAME_CONFIG, POWERUP_TYPES } from '../utils/constants.js';

export class PowerUp {
    constructor(grid) {
        this.grid = grid;
        this.active = false;
        this.position = { x: 0, y: 0 };
        this.type = POWERUP_TYPES.NORMAL;
        this.config = GAME_CONFIG.POWER_UPS.NORMAL;
        this.animationPhase = 0;
        this.duration = 0;  // 剩余持续时间（毫秒）
    }

    /**
     * 随机生成道具
     */
    generate(excludePositions = [], forceType = null) {
        // 随机决定道具类型
        const types = Object.values(POWERUP_TYPES);
        // 权重：普通食物60%，其他道具40%
        const rand = Math.random();
        if (forceType) {
            this.type = forceType;
        } else if (rand < 0.6) {
            this.type = POWERUP_TYPES.NORMAL;
        } else {
            // 随机选择特殊道具
            const specialTypes = [POWERUP_TYPES.SPEED, POWERUP_TYPES.SHIELD, POWERUP_TYPES.GROWTH, POWERUP_TYPES.SLOW];
            this.type = specialTypes[Math.floor(Math.random() * specialTypes.length)];
        }

        this.config = GAME_CONFIG.POWER_UPS[this.type.toUpperCase()];
        this.position = this.grid.getRandomPosition(excludePositions);
        this.active = true;
        this.animationPhase = 0;
        this.duration = this.config.duration || 0;
    }

    /**
     * 生成普通食物
     */
    generateFood(excludePositions = []) {
        this.type = POWERUP_TYPES.NORMAL;
        this.config = GAME_CONFIG.POWER_UPS.NORMAL;
        this.position = this.grid.getRandomPosition(excludePositions);
        this.active = true;
        this.animationPhase = 0;
    }

    /**
     * 更新道具状态
     */
    update(deltaTime) {
        if (!this.active) return;

        // 更新动画相位
        this.animationPhase += 0.15;
        if (this.animationPhase > Math.PI * 2) {
            this.animationPhase = 0;
        }

        // 更新持续时间
        if (this.duration > 0) {
            this.duration -= deltaTime;
            if (this.duration <= 0) {
                this.duration = 0;
            }
        }
    }

    /**
     * 获取当前动画缩放比例
     */
    getScale() {
        return 0.8 + Math.sin(this.animationPhase) * 0.2;
    }

    /**
     * 获取旋转角度
     */
    getRotation() {
        return this.animationPhase;
    }

    /**
     * 获取分数
     */
    getScore() {
        return this.config.score || 0;
    }

    /**
     * 获取生长数量（用于growth类型）
     */
    getGrowAmount() {
        return this.config.growAmount || 1;
    }

    /**
     * 是否是特殊道具（需要buff效果）
     */
    isSpecial() {
        return this.type !== POWERUP_TYPES.NORMAL;
    }

    /**
     * 是否正在生效
     */
    isActive() {
        return this.active;
    }

    /**
     * 检查道具是否在指定位置
     */
    isAt(x, y) {
        return this.position.x === x && this.position.y === y;
    }

    /**
     * 销毁道具
     */
    deactivate() {
        this.active = false;
    }
}

/**
 * 道具效果管理器
 */
export class PowerUpManager {
    constructor() {
        this.activeEffects = {
            shield: false,
            speed: false,
            slow: false
        };
        this.effectTimers = {
            shield: 0,
            speed: 0,
            slow: 0
        };
    }

    /**
     * 激活道具效果
     */
    applyEffect(powerUpType) {
        switch (powerUpType) {
            case POWERUP_TYPES.SHIELD:
                this.activeEffects.shield = true;
                break;
            case POWERUP_TYPES.SPEED:
                this.activeEffects.speed = true;
                break;
            case POWERUP_TYPES.SLOW:
                this.activeEffects.slow = true;
                break;
        }
    }

    /**
     * 更新效果计时器
     */
    update(deltaTime) {
        // 更新护盾
        if (this.activeEffects.shield) {
            this.effectTimers.shield -= deltaTime;
            if (this.effectTimers.shield <= 0) {
                this.activeEffects.shield = false;
            }
        }

        // 更新加速
        if (this.activeEffects.speed) {
            this.effectTimers.speed -= deltaTime;
            if (this.effectTimers.speed <= 0) {
                this.activeEffects.speed = false;
            }
        }

        // 更新减速
        if (this.activeEffects.slow) {
            this.effectTimers.slow -= deltaTime;
            if (this.effectTimers.slow <= 0) {
                this.activeEffects.slow = false;
            }
        }
    }

    /**
     * 设置效果持续时间
     */
    setEffectDuration(effectType, duration) {
        this.effectTimers[effectType] = duration;
    }

    /**
     * 检查是否有护盾
     */
    hasShield() {
        return this.activeEffects.shield;
    }

    /**
     * 检查是否加速中
     */
    isSpeedBoost() {
        return this.activeEffects.speed;
    }

    /**
     * 检查是否减速中
     */
    isSlowed() {
        return this.activeEffects.slow;
    }

    /**
     * 清除所有效果
     */
    clearAll() {
        this.activeEffects = {
            shield: false,
            speed: false,
            slow: false
        };
        this.effectTimers = {
            shield: 0,
            speed: 0,
            slow: 0
        };
    }

    /**
     * 获取速度倍率
     */
    getSpeedMultiplier() {
        let multiplier = 1;
        if (this.activeEffects.speed) multiplier *= 1.5;  // 加速50%
        if (this.activeEffects.slow) multiplier *= 0.5;   // 减速50%
        return multiplier;
    }
}


