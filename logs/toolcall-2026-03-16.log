 * 粒子系统 - 用于食物特效和死亡效果
 */
import { GAME_CONFIG } from '../utils/constants.js';

class Particle {
    constructor() {
        this.reset();
    }

    reset() {
        this.x = 0;
        this.y = 0;
        this.vx = 0;
        this.vy = 0;
        this.life = 0;
        this.maxLife = 0;
        this.color = '#ffffff';
        this.size = 0;
        this.active = false;
    }

    init(x, y, color, speed, size, life) {
        this.x = x;
        this.y = y;
        const angle = Math.random() * Math.PI * 2;
        const velocity = Math.random() * speed;
        this.vx = Math.cos(angle) * velocity;
        this.vy = Math.sin(angle) * velocity;
        this.life = life;
        this.maxLife = life;
        this.color = color;
        this.size = size;
        this.active = true;
    }

    update() {
        if (!this.active) return;

        this.x += this.vx;
        this.y += this.vy;
        this.life--;
        
        // 减速效果
        this.vx *= 0.98;
        this.vy *= 0.98;

        if (this.life <= 0) {
            this.active = false;
        }
    }

    draw(ctx) {
        if (!this.active) return;

        const alpha = this.life / this.maxLife;
        const currentSize = this.size * alpha;

        ctx.save();
        ctx.globalAlpha = alpha;
        ctx.globalCompositeOperation = 'lighter';
        ctx.fillStyle = this.color;
        ctx.shadowBlur = 10;
        ctx.shadowColor = this.color;
        
        ctx.beginPath();
        ctx.arc(this.x, this.y, currentSize, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
    }
}

export class ParticleSystem {
    constructor() {
        this.particles = [];
        this.maxParticles = 100;
        
        // 初始化粒子池
        for (let i = 0; i < this.maxParticles; i++) {
            this.particles.push(new Particle());
        }
    }

    /**
     * 发射粒子
     */
    emit(x, y, color, count = 20) {
        const available = this.particles.filter(p => !p.active);
        const toEmit = Math.min(count, available.length);
        
        for (let i = 0; i < toEmit; i++) {
            const particle = available[i];
            particle.init(
                x, 
                y, 
                color,
                3 + Math.random() * 3,  // 速度
                3 + Math.random() * 3,  // 大小
                30 + Math.random() * 20  // 生命周期
            );
        }
    }

    /**
     * 发射食物吃掉特效
     */
    emitFoodEat(x, y) {
        const colors = ['#ff00ff', '#ff66ff', '#ff99ff', '#00ffff', '#00ccff'];
        const color = colors[Math.floor(Math.random() * colors.length)];
        this.emit(x, y, color, GAME_CONFIG.PARTICLE_COUNT);
    }

    /**
     * 发射死亡特效
     */
    emitDeath(x, y) {
        const colors = ['#ff0000', '#ff6600', '#ff0066', '#ff3300'];
        for (let i = 0; i < 50; i++) {
            const color = colors[Math.floor(Math.random() * colors.length)];
            this.emit(x, y, color, 10);
        }
    }

    /**
     * 更新所有粒子
     */
    update() {
        this.particles.forEach(p => p.update());
    }

    /**
     * 渲染所有粒子
     */
    render(ctx) {
        this.particles.forEach(p => p.draw(ctx));
    }

    /**
     * 清空所有粒子
     */
    clear() {
        this.particles.forEach(p => p.active = false);
    }
}


