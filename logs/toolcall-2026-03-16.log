1	/**
  2	 * 蛇类 - 管理蛇的数据结构和移动逻辑
  3	 */
  4	import { DIRECTIONS, GAME_CONFIG } from '../utils/constants.js';
  5	
  6	export class Snake {
  7	    constructor(grid) {
  8	        this.grid = grid;
  9	        this.positions = [];         // 蛇身所有位置的数组
 10	        this.direction = DIRECTIONS.RIGHT;    // 当前移动方向
 11	        this.nextDirection = DIRECTIONS.RIGHT; // 下一帧方向（防止快速按键导致掉头）
 12	        this.growPending = 0;        // 待生长长度
 13	        this.alive = true;
 14	        this.score = 0;
 15	        
 16	        this.reset();
 17	    }
 18	
 19	    /**
 20	     * 初始化蛇
 21	     */
 22	    reset() {
 23	        const startX = Math.floor(this.grid.cols / 2);
 24	        const startY = Math.floor(this.grid.rows / 2);
 25	        
 26	        // 从中间开始，蛇头朝右
 27	        this.positions = [
 28	            { x: startX, y: startY },
 29	            { x: startX - 1, y: startY },
 30	            { x: startX - 2, y: startY }
 31	        ];
 32	        
 33	        this.direction = DIRECTIONS.RIGHT;
 34	        this.nextDirection = DIRECTIONS.RIGHT;
 35	        this.growPending = 0;
 36	        this.alive = true;
 37	        this.score = 0;
 38	    }
 39	
 40	    /**
 41	     * 获取蛇头位置
 42	     */
 43	    getHead() {
 44	        return this.positions[0];
 45	    }
 46	
 47	    /**
 48	     * 获取蛇身位置（不含头）
 49	     */
 50	    getBody() {
 51	        return this.positions.slice(1);
 52	    }
 53	
 54	    /**
 55	     * 设置移动方向（带防反向逻辑）
 56	     */
 57	    setDirection(newDirection) {
 58	        // 防止直接反向（不能向左转时直接向右）
 59	        const isOpposite = (
 60	            this.direction.x !== 0 && newDirection.x === -this.direction.x
 61	        ) || (
 62	            this.direction.y !== 0 && newDirection.y === -this.direction.y
 63	        );
 64	        
 65	        if (!isOpposite) {
 66	            this.nextDirection = newDirection;
 67	        }
 68	    }
 69	
 70	    /**
 71	     * 更新蛇的位置（每帧调用）
 72	     */
 73	    update() {
 74	        if (!this.alive) return;
 75	
 76	        // 应用方向
 77	        this.direction = this.nextDirection;
 78	
 79	        // 计算新蛇头位置
 80	        const head = this.getHead();
 81	        const newHead = {
 82	            x: head.x + this.direction.x,
 83	            y: head.y + this.direction.y
 84	        };
 85	
 86	        // 碰撞检测 - 边界
 87	        if (!this.grid.isValid(newHead.x, newHead.y)) {
 88	            this.die();
 89	            return;
 90	        }
 91	
 92	        // 碰撞检测 - 自身
 93	        if (this.checkSelfCollision(newHead)) {
 94	            this.die();
 95	            return;
 96	        }
 97	
 98	        // 添加新蛇头
 99	        this.positions.unshift(newHead);
100	
101	        // 如果需要生长则保留蛇尾，否则移除
102	        if (this.growPending > 0) {
103	            this.growPending--;
104	        } else {
105	            this.positions.pop();
106	        }
107	    }
108	
109	    /**
110	     * 检查是否吃到食物
111	     */
112	    checkFood(foodPosition) {
113	        const head = this.getHead();
114	        return head.x === foodPosition.x && head.y === foodPosition.y;
115	    }
116	
117	    /**
118	     * 吃到食物后的处理
119	     */
120	    eatFood() {
121	        // 增加待生长长度
122	        this.growPending += 1;
123	        
124	        // 增加分数
125	        this.score += GAME_CONFIG.FOOD_SCORE;
126	        
127	        return this.score;
128	    }
129	
130	    /**
131	     * 检查是否撞到自己
132	     */
133	    checkSelfCollision(position) {
134	        // 检查是否与身体任何部分碰撞（跳过蛇头）
135	        for (let i = 1; i < this.positions.length; i++) {
136	            if (this.positions[i].x === position.x && 
137	                this.positions[i].y === position.y) {
138	                return true;
139	            }
140	        }
141	        return false;
142	    }
143	
144	    /**
145	     * 蛇死亡
146	     */
147	    die() {
148	        this.alive = false;
149	    }
150	
151	    /**
152	     * 获取速度（根据长度调整）
153	     */
154	    getSpeed() {
155	        const speed = GAME_CONFIG.BASE_SPEED - 
156	            Math.floor(this.positions.length / 5) * GAME_CONFIG.SPEED_INCREMENT;
157	        return Math.max(speed, GAME_CONFIG.MIN_SPEED);
158	    }
