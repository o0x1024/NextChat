{"file_path":"/Users/like/code/apptest/src/core/Snake.js","new_string":"/**\n * 蛇类 - 管理蛇的数据结构和移动逻辑\n */\nimport { DIRECTIONS, GAME_CONFIG, POWERUP_TYPES } from '../utils/constants.js';\n\nexport class Snake {\n    constructor(grid) {\n        this.grid = grid;\n        this.positions = [];         // 蛇身所有位置的数组\n        this.direction = DIRECTIONS.RIGHT;    // 当前移动方向\n        this.nextDirection = DIRECTIONS.RIGHT; // 下一帧方向（防止快速按键导致掉头）\n        this.growPending = 0;        // 待生长长度\n        this.alive = true;\n        this.score = 0;\n\n        // 特殊状态\n        this.hasShield = false;      // 护盾状态（可穿墙）\n        this.speedBoost = false;     // 加速状态\n        this.slowed = false;         // 减速状态\n\n        this.reset();\n    }\n\n    /**\n     * 初始化蛇\n     */\n    reset() {\n        const startX = Math.floor(this.grid.cols / 2);\n        const startY = Math.floor(this.grid.rows / 2);\n\n        // 从中间开始，蛇头朝右\n        this.positions = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n\n        this.direction = DIRECTIONS.RIGHT;\n        this.nextDirection = DIRECTIONS.RIGHT;\n        this.growPending = 0;\n        this.alive = true;\n        this.score = 0;\n\n        // 重置状态\n        this.hasShield = false;\n        this.speedBoost = false;\n        this.slowed = false;\n    }\n\n    /**\n     * 获取蛇头位置\n     */\n    getHead() {\n        return this.positions[0];\n    }\n\n    /**\n     * 获取蛇身位置（不含头）\n     */\n    getBody() {\n        return this.positions.slice(1);\n    }\n\n    /**\n     * 设置移动方向（带防反向逻辑）\n     */\n    setDirection(newDirection) {\n        // 防止直接反向（不能向左转时直接向右）\n        const isOpposite = (\n            this.direction.x !== 0 && newDirection.x === -this.direction.x\n        ) || (\n            this.direction.y !== 0 && newDirection.y === -this.direction.y\n        );\n\n        if (!isOpposite) {\n            this.nextDirection = newDirection;\n        }\n    }\n\n    /**\n     * 更新蛇的位置（每帧调用）\n     */\n    update() {\n        if (!this.alive) return;\n\n        // 应用方向\n        this.direction = this.nextDirection;\n\n        // 计算新蛇头位置\n        const head = this.getHead();\n        let newHead = {\n            x: head.x + this.direction.x,\n            y: head.y + this.direction.y\n        };\n\n        // 护盾状态下，穿墙处理\n        if (this.hasShield) {\n            if (newHead.x < 0) newHead.x = this.grid.cols - 1;\n            if (newHead.x >= this.grid.cols) newHead.x = 0;\n            if (newHead.y < 0) newHead.y = this.grid.rows - 1;\n            if (newHead.y >= this.grid.rows) newHead.y = 0;\n        } else {\n            // 普通模式：边界碰撞检测\n            if (!this.grid.isValid(newHead.x, newHead.y)) {\n                this.die();\n                return;\n            }\n        }\n\n        // 自身碰撞检测（护盾状态下不检测自身碰撞）\n        if (!this.hasShield && this.checkSelfCollision(newHead)) {\n            this.die();\n            return;\n        }\n\n        // 添加新蛇头\n        this.positions.unshift(newHead);\n\n        // 如果需要生长则保留蛇尾，否则移除\n        if (this.growPending > 0) {\n            this.growPending--;\n        } else {\n            this.positions.pop();\n        }\n    }\n\n    /**\n     * 检查是否吃到食物/道具\n     */\n    checkFood(foodPosition) {\n        const head = this.getHead();\n        return head.x === foodPosition.x && head.y === foodPosition.y;\n    }\n\n    /**\n     * 吃到食物/道具后的处理\n     */\n    eatFood(powerUp) {\n        // 增加待生长长度\n        this.growPending += powerUp.getGrowAmount();\n\n        // 增加分数\n        this.score += powerUp.getScore();\n\n        // 应用特殊效果\n        if (powerUp.isSpecial()) {\n            this.applyPowerUpEffect(powerUp.type);\n        }\n\n        return this.score;\n    }\n\n    /**\n     * 应用道具效果\n     */\n    applyPowerUpEffect(type) {\n        switch (type) {\n            case POWERUP_TYPES.SPEED:\n                this.speedBoost = true;\n                setTimeout(() => { this.speedBoost = false; }, 3000);\n                break;\n            case POWERUP_TYPES.SHIELD:\n                this.hasShield = true;\n                setTimeout(() => { this.hasShield = false; }, 5000);\n                break;\n            case POWERUP_TYPES.GROWTH:\n                this.growPending += 2;  // 额外生长\n                break;\n            case POWERUP_TYPES.SLOW:\n                this.slowed = true;\n                setTimeout(() => { this.slowed = false; }, 4000);\n                break;\n        }\n    }\n\n    /**\n     * 检查是否撞到自己\n     */\n    checkSelfCollision(position) {\n        // 检查是否与身体任何部分碰撞（跳过蛇头）\n        for (let i = 1; i < this.positions.length; i++) {\n            if (this.positions[i].x === position.x &&\n                this.positions[i].y === position.y) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    /**\n     * 蛇死亡\n     */\n    die() {\n        this.alive = false;\n    }\n\n    /**\n     * 获取速度（根据长度和状态调整）\n     */\n    getSpeed() {\n        let speed = GAME_CONFIG.BASE_SPEED -\n            Math.floor(this.positions.length / 5) * GAME_CONFIG.SPEED_INCREMENT;\n\n        // 加速状态\n        if (this.speedBoost) {\n            speed *= 0.6;  // 速度提升40%\n        }\n\n        // 减速状态\n        if (this.slowed) {\n            speed *= 1.5;  // 速度降低40%\n        }\n\n        return Math.max(speed, GAME_CONFIG.MIN_SPEED);\n    }\n\n    /**\n     * 是否有护盾\n     */\n    isShielded() {\n        return this.hasShield;\n    }\n\n    /**\n     * 清除所有状态效果\n     */\n    clearEffects() {\n        this.hasShield = false;\n        this.speedBoost = false;\n        this.slowed = false;\n    }\n}","old_string":"/**\n * 蛇类 - 管理蛇的数据结构和移动逻辑\n */\nimport { DIRECTIONS, GAME_CONFIG } from '../utils/constants.js';\n\nexport class Snake {\n    constructor(grid) {\n        this.grid = grid;\n        this.positions = [];         // 蛇身所有位置的数组\n        this.direction = DIRECTIONS.RIGHT;    // 当前移动方向\n        this.nextDirection = DIRECTIONS.RIGHT; // 下一帧方向（防止快速按键导致掉头）\n        this.growPending = 0;        // 待生长长度\n        this.alive = true;\n        this.score = 0;\n        \n        this.reset();\n    }\n\n    /**\n     * 初始化蛇\n     */\n    reset() {\n        const startX = Math.floor(this.grid.cols / 2);\n        const startY = Math.floor(this.grid.rows / 2);\n        \n        // 从中间开始，蛇头朝右\n        this.positions = [\n            { x: startX, y: startY },\n            { x: startX - 1, y: startY },\n            { x: startX - 2, y: startY }\n        ];\n        \n        this.direction = DIRECTIONS.RIGHT;\n        this.nextDirection = DIRECTIONS.RIGHT;\n        this.growPending = 0;\n        this.alive = true;\n        this.score = 0;\n    }\n\n    /**\n     * 获取蛇头位置\n     */\n    getHead() {\n        return this.positions[0];\n    }\n\n    /**\n     * 获取蛇身位置（不含头）\n     */\n    getBody() {\n        return this.positions.slice(1);\n    }\n\n    /**\n     * 设置移动方向（带防反向逻辑）\n     */\n    setDirection(newDirection) {\n        // 防止直接反向（不能向左转时直接向右）\n        const isOpposite = (\n            this.direction.x !== 0 && newDirection.x === -this.direction.x\n        ) || (\n            this.direction.y !== 0 && newDirection.y === -this.direction.y\n        );\n        \n        if (!isOpposite) {\n            this.nextDirection = newDirection;\n        }\n    }\n\n    /**\n     * 更新蛇的位置（每帧调用）\n     */\n    update() {\n        if (!this.alive) return;\n\n        // 应用方向\n        this.direction = this.nextDirection;\n\n        // 计算新蛇头位置\n        const head = this.getHead();\n        const newHead = {\n            x: head.x + this.direction.x,\n            y: head.y + this.direction.y\n        };\n\n        // 碰撞检测 - 边界\n        if (!this.grid.isValid(newHead.x, newHead.y)) {\n            this.die();\n            return;\n        }\n\n        // 碰撞检测 - 自身\n        if (this.checkSelfCollision(newHead)) {\n            this.die();\n            return;\n        }\n\n        // 添加新蛇头\n        this.positions.unshift(newHead