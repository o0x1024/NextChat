{"file_path": "/Users/like/code/apptest/src/core/Game.js", "new_string": "/**\n * 游戏主类 - 整合所有模块，控制游戏流程\n */\nimport { GAME_CONFIG, GAME_STATE, GAME_MODE } from '../utils/constants.js';\nimport { Grid } from './Grid.js';\nimport { Snake } from './Snake.js';\nimport { Food } from './Food.js';\nimport { PowerUp, PowerUpManager } from './PowerUp.js';\nimport { ObstacleManager } from './Obstacle.js';\nimport { GameModeManager } from './GameMode.js';\nimport { Renderer } from '../renderer/Renderer.js';\nimport { ParticleSystem } from '../renderer/ParticleSystem.js';\nimport { InputManager } from '../input/InputManager.js';\n\nexport class Game {\n    constructor(canvasId) {\n        // 获取画布\n        const canvas = document.getElementById(canvasId);\n        if (!canvas) {\n            throw new Error(`Canvas element \"${canvasId}\" not found`);\n        }\n\n        // 初始化模块\n        this.grid = new Grid();\n        this.snake = new Snake(this.grid);\n        this.powerUp = new PowerUp(this.grid);\n        this.powerUpManager = new PowerUpManager();\n        this.obstacleManager = new ObstacleManager(this.grid);\n        this.gameModeManager = new GameModeManager();\n        this.renderer = new Renderer(canvas);\n        this.particles = new ParticleSystem();\n        this.input = new InputManager();\n\n        // 设置渲染器网格引用\n        this.renderer.setGrid(this.grid);\n\n        // 游戏状态\n        this.state = GAME_STATE.IDLE;\n        this.score = 0;\n        this.highScore = this.loadHighScore();\n        this.currentMode = GAME_MODE.CLASSIC;\n\n        // 游戏循环\n        this.lastUpdateTime = 0;\n        this.gameLoopId = null;\n        this.lastFrameTime = 0;  // 用于计算deltaTime\n\n        // 绑定UI元素\n        this.bindUI();\n\n        // 设置输入处理\n        this.setupInput();\n\n        // 初始化UI\n        this.updateScoreDisplay();\n        this.updateHighScoreDisplay();\n        this.setupModeButtons();\n    }\n\n    /**\n     * 绑定UI元素\n     */\n    bindUI() {\n        this.startScreen = document.getElementById('start-screen');\n        this.gameOverScreen = document.getElementById('game-over-screen');\n        this.pauseScreen = document.getElementById('pause-screen');\n        this.scoreDisplay = document.getElementById('score');\n        this.highScoreDisplay = document.getElementById('high-score');\n        this.finalScoreDisplay = document.getElementById('final-score');\n        this.modeDisplay = document.getElementById('mode-display');\n        this.timeDisplay = document.getElementById('time-display');\n\n        // 绑定按钮事件\n        document.getElementById('start-btn')?.addEventListener('click', () => this.start());\n        document.getElementById('restart-btn')?.addEventListener('click', () => this.restart());\n        document.getElementById('resume-btn')?.addEventListener('click', () => this.resume());\n\n        // 模式选择按钮\n        this.setupModeButtons();\n    }\n\n    /**\n     * 设置模式选择按钮\n     */\n    setupModeButtons() {\n        const modes = [\n            { id: 'classic-btn', mode: GAME_MODE.CLASSIC },\n            { id: 'challenge-btn', mode: GAME_MODE.CHALLENGE },\n            { id: 'time-attack-btn', mode: GAME_MODE.TIME_ATTACK },\n            { id: 'endless-btn', mode: GAME_MODE.ENDLESS }\n        ];\n\n        modes.forEach(({ id, mode }) => {\n            const btn = document.getElementById(id);\n            if (btn) {\n                btn.addEventListener('click', () => {\n                    this.currentMode = mode;\n                    this.gameModeManager.setMode(mode);\n                    this.start();\n                });\n            }\n        });\n    }\n\n    /**\n     * 设置输入处理\n     */\n    setupInput() {\n        this.input.onKey((event) => {\n            if (event.type === 'direction') {\n                if (this.state === GAME_STATE.PLAYING) {\n                    this.snake.setDirection(event.direction);\n                }\n            } else if (event.type === 'pause') {\n                if (this.state === GAME_STATE.PLAYING) {\n                    this.pause();\n                } else if (this.state === GAME_STATE.PAUSED) {\n                    this.resume();\n                }\n            }\n        });\n\n        this.input.onTouch((event) => {\n            if (event.type === 'direction' && this.state === GAME_STATE.PLAYING) {\n                this.snake.setDirection(event.direction);\n            }\n        });\n    }\n\n    /**\n     * 开始游戏\n     */\n    start() {\n        this.reset();\n        this.state = GAME_STATE.PLAYING;\n        this.hideAllScreens();\n\n        // 设置游戏模式\n        this.gameModeManager.setMode(this.currentMode);\n        this.gameModeManager.startMode();\n\n        // 初始化障碍物（根据模式）\n        const mode = this.gameModeManager.getCurrentMode();\n        const obstacleCount = mode.getObstacleCount();\n        this.obstacleManager.initialize(this.snake.positions, obstacleCount);\n\n        // 生成食物\n        const occupiedPositions = [...this.snake.positions, ...this.obstacleManager.getPositions()];\n        this.powerUp.generateFood(occupiedPositions);\n\n        // 清除蛇的特殊状态\n        this.snake.clearEffects();\n\n        this.updateModeDisplay();\n        this.startGameLoop();\n    }\n\n    /**\n     * 重新开始\n     */\n    restart() {\n        this.start();\n    }\n\n    /**\n     * 暂停游戏\n     */\n    pause() {\n        if (this.state !== GAME_STATE.PLAYING) return;\n\n        this.state = GAME_STATE.PAUSED;\n        this.pauseScreen.classList.remove('hidden');\n    }\n\n    /**\n     * 继续游戏\n     */\n    resume() {\n        if (this.state !== GAME_STATE.PAUSED) return;\n\n        this.state = GAME_STATE.PLAYING;\n        this.pauseScreen.classList.add('hidden');\n        this.lastUpdateTime = performance.now();\n        this.lastFrameTime = performance.now();\n    }\n\n    /**\n     * 游戏结束\n     */\n    gameOver() {\n        this.state = GAME_STATE.GAME_OVER;\n        this.stopGameLoop();\n        this.gameModeManager.stopMode();\n\n       