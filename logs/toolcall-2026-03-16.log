     * 清除所有效果
     */
    clearAll() {
        this.activeEffects = {
            shield: false,
            speed: false,
            slow: false
        };
        this.effectTimers = {
            shield: 0,
            speed: 0,
            slow: 0
        };
    }

    /**
     * 获取速度倍率
     */
    getSpeedMultiplier() {
        let multiplier = 1;
        if (this.activeEffects.speed) multiplier *= 1.5;  // 加速50%
        if (this.activeEffects.slow) multiplier *= 0.5;   // 减速50%
        return multiplier;
    }
