  4	import { GAME_CONFIG, GAME_STATE } from '../utils/constants.js';
  5	import { Grid } from './Grid.js';
  6	import { Snake } from './Snake.js';
  7	import { Food } from './Food.js';
  8	import { Renderer } from '../renderer/Renderer.js';
  9	import { ParticleSystem } from '../renderer/ParticleSystem.js';
 10	import { InputManager } from '../input/InputManager.js';
 11	
 12	export class Game {
 13	    constructor(canvasId) {
 14	        // 获取画布
 15	        const canvas = document.getElementById(canvasId);
 16	        if (!canvas) {
 17	            throw new Error(`Canvas element "${canvasId}" not found`);
 18	        }
 19	
 20	        // 初始化模块
 21	        this.grid = new Grid();
 22	        this.snake = new Snake(this.grid);
 23	        this.food = new Food(this.grid);
 24	        this.renderer = new Renderer(canvas);
 25	        this.particles = new ParticleSystem();
 26	        this.input = new InputManager();
 27	
 28	        // 设置渲染器网格引用
 29	        this.renderer.setGrid(this.grid);
 30	
 31	        // 游戏状态
 32	        this.state = GAME_STATE.IDLE;
 33	        this.score = 0;
 34	        this.highScore = this.loadHighScore();
 35	
 36	        // 游戏循环
 37	        this.lastUpdateTime = 0;
 38	        this.gameLoopId = null;
 39	
 40	        // 绑定UI元素
 41	        this.bindUI();
 42	
 43	        // 设置输入处理
 44	        this.setupInput();
 45	
 46	        // 初始化UI
 47	        this.updateScoreDisplay();
 48	        this.updateHighScoreDisplay();
 49	    }
 50	
 51	    /**
 52	     * 绑定UI元素
 53	     */
 54	    bindUI() {
 55	        this.startScreen = document.getElementById('start-screen');
 56	        this.gameOverScreen = document.getElementById('game-over-screen');
 57	        this.pauseScreen = document.getElementById('pause-screen');
 58	        this.scoreDisplay = document.getElementById('score');
 59	        this.highScoreDisplay = document.getElementById('high-score');
 60	        this.finalScoreDisplay = document.getElementById('final-score');
 61	
 62	        // 绑定按钮事件
 63	        document.getElementById('start-btn')?.addEventListener('click', () => this.start());
 64	        document.getElementById('restart-btn')?.addEventListener('click', () => this.restart());
 65	        document.getElementById('resume-btn')?.addEventListener('click', () => this.resume());
 66	    }
 67	
 68	    /**
 69	     * 设置输入处理
 70	     */
 71	    setupInput() {
 72	        this.input.onKey((event) => {
 73	            if (event.type === 'direction') {
 74	                if (this.state === GAME_STATE.PLAYING) {
 75	                    this.snake.setDirection(event.direction);
 76	                }
 77	            } else if (event.type === 'pause') {
 78	                if (this.state === GAME_STATE.PLAYING) {
 79	                    this.pause();
 80	                } else if (this.state === GAME_STATE.PAUSED) {
 81	                    this.resume();
 82	                }
 83	            }
 84	        });
 85	
 86	        this.input.onTouch((event) => {
 87	            if (event.type === 'direction' && this.state === GAME_STATE.PLAYING) {
 88	                this.snake.setDirection(event.direction);
 89	            }
 90	        });
 91	    }
 92	
 93	    /**
 94	     * 开始游戏
 95	     */
 96	    start() {
 97	        this.reset();
 98	        this.state = GAME_STATE.PLAYING;
 99	        this.hideAllScreens();
100	        this.startGameLoop();
101	    }
102	
103	    /**
104	     * 重新开始
105	     */
106	    restart() {
107	        this.start();
108	    }
109	
110	    /**
111	     * 暂停游戏
112	     */
113	    pause() {
114	        if (this.state !== GAME_STATE.PLAYING) return;
115	        
