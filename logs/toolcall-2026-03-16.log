{"file_path":"/Users/like/code/apptest/src/core/Game.js","new_string":"    /**\n     * 开始游戏循环\n     */\n    startGameLoop() {\n        this.lastUpdateTime = performance.now();\n        this.lastFrameTime = performance.now();\n\n        const loop = (currentTime) => {\n            const deltaTime = currentTime - this.lastFrameTime;\n            this.lastFrameTime = currentTime;\n\n            if (this.state === GAME_STATE.PLAYING) {\n                const speed = this.snake.getSpeed();\n\n                // 更新时间（限时模式）\n                const mode = this.gameModeManager.getCurrentMode();\n                if (mode.hasTimeLimit()) {\n                    const timeUp = mode.updateTime(deltaTime);\n                    this.updateTimeDisplay();\n                    if (timeUp) {\n                        this.gameOver();\n                        return;\n                    }\n                }\n\n                // 更新效果管理器\n                this.powerUpManager.update(deltaTime);\n\n                // 同步蛇的状态\n                this.snake.hasShield = this.powerUpManager.hasShield();\n                this.snake.speedBoost = this.powerUpManager.isSpeedBoost();\n                this.snake.slowed = this.powerUpManager.isSlowed();\n\n                const deltaTimeSinceUpdate = currentTime - this.lastUpdateTime;\n                if (deltaTimeSinceUpdate >= speed) {\n                    this.update();\n                    this.lastUpdateTime = currentTime;\n                }\n            }\n\n            // 始终渲染（保持动画效果）\n            this.render();\n            this.gameLoopId = requestAnimationFrame(loop);\n        };\n\n        this.gameLoopId = requestAnimationFrame(loop);\n    }","old_string":"    /**\n     * 开始游戏循环\n     */\n    startGameLoop() {\n        this.lastUpdateTime = performance.now();\n        const loop = (currentTime) => {\n            if (this.state === GAME_STATE.PLAYING) {\n                const deltaTime = currentTime - this.lastUpdateTime;\n                const 