1	/**
  2	 * 障碍物系统 - 管理地形障碍
  3	 */
  4	import { GAME_CONFIG } from '../utils/constants.js';
  5	
  6	export class Obstacle {
  7	    constructor(grid, x, y) {
  8	        this.grid = grid;
  9	        this.position = { x, y };
 10	        this.active = true;
 11	        this.animationPhase = Math.random() * Math.PI * 2;
 12	    }
 13	
 14	    /**
 15	     * 检查指定位置是否有障碍物
 16	     */
 17	    isAt(x, y) {
 18	        return this.active && this.position.x === x && this.position.y === y;
 19	    }
 20	
 21	    /**
 22	     * 更新动画
 23	     */
 24	    update() {
 25	        this.animationPhase += 0.05;
 26	        if (this.animationPhase > Math.PI * 2) {
 27	            this.animationPhase = 0;
 28	        }
 29	    }
 30	}
 31	
 32	export class ObstacleManager {
 33	    constructor(grid) {
 34	        this.grid = grid;
 35	        this.obstacles = [];
 36	    }
 37	
 38	    /**
 39	     * 初始化障碍物
 40	     */
 41	    initialize(excludePositions = [], count = 5) {
 42	        this.obstacles = [];
 43	        const maxAttempts = this.grid.cols * this.grid.rows;
 44	        let attempts = 0;
 45	
 46	        while (this.obstacles.length < count && attempts < maxAttempts) {
 47	            const x = Math.floor(Math.random() * this.grid.cols);
 48	            const y = Math.floor(Math.random() * this.grid.rows);
 49	
 50	            // 检查是否与排除位置冲突
 51	            const isOccupied = excludePositions.some(pos => pos.x === x && pos.y === y);
 52	
 53	            // 检查是否与已有障碍物冲突
 54	            const isDuplicate = this.obstacles.some(obs => obs.position.x === x && obs.position.y === y);
 55	
 56	            // 排除边缘位置（给蛇留出空间）
 57	            const isEdge = x === 0 || x === this.grid.cols - 1 ||
 58	                          y === 0 || y === this.grid.rows - 1;
 59	
 60	            if (!isOccupied && !isDuplicate && !isEdge) {
 61	                this.obstacles.push(new Obstacle(this.grid, x, y));
 62	            }
 63	
 64	            attempts++;
 65	        }
 66	    }
 67	
 68	    /**
 69	     * 检查指定位置是否有障碍物
 70	     */
 71	    hasObstacle(x, y) {
 72	        return this.obstacles.some(obs => obs.isAt(x, y));
 73	    }
 74	
 75	    /**
 76	     * 获取所有障碍物位置
 77	     */
 78	    getPositions() {
 79	        return this.obstacles.map(obs => obs.position);
 80	    }
 81	
 82	    /**
 83	     * 更新所有障碍物
