192	            }
193	            
194	            // 始终渲染（保持动画效果）
195	            this.render();
196	            this.gameLoopId = requestAnimationFrame(loop);
197	        };
198	        
199	        this.gameLoopId = requestAnimationFrame(loop);
200	    }
201	
202	    /**
203	     * 停止游戏循环
204	     */
205	    stopGameLoop() {
206	        if (this.gameLoopId) {
