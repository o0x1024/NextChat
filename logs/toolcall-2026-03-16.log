/**
 * 食物类 - 管理食物生成和状态
 */
import { GAME_CONFIG } from '../utils/constants.js';

export class Food {
    constructor(grid) {
        this.grid = grid;
        this.position = { x: 0, y: 0 };
        this.active = false;
        this.animationPhase = 0;
        
        this.generate();
    }

    /**
     * 生成新食物位置
     */
    generate(excludePositions = []) {
        this.position = this.grid.getRandomPosition(excludePositions);
        this.active = true;
        this.animationPhase = 0;
    }

    /**
     * 获取食物位置
     */
    getPosition() {
        return this.position;
    }

    /**
     * 更新动画相位
     */
    update() {
        if (this.active) {
            this.animationPhase += 0.1;
            if (this.animationPhase > Math.PI * 2) {
                this.animationPhase = 0;
            }
        }
    }

    /**
     * 获取当前动画缩放比例（用于脉冲效果）
     */
    getScale() {
        // 0.8 到 1.2 之间的脉冲
        return 0.8 + Math.sin(this.animationPhase) * 0.2;
    }

    /**
     * 获取霓虹颜色（用于渲染）
     */
    getColor() {
        return GAME_CONFIG.COLORS.FOOD;
    }

    /**
     * 获取发光颜色
     */
    getGlowColor() {
        return GAME_CONFIG.COLORS.FOOD_GLOW;
    }

    /**
     * 检查食物是否在指定位置
     */
    isAt(x, y) {
        return this.position.x === x && this.position.y === y;
    }
}


