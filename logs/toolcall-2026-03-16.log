/**
 * 游戏主类 - 整合所有模块，控制游戏流程
 */
import { GAME_CONFIG, GAME_STATE } from '../utils/constants.js';
import { Grid } from './Grid.js';
import { Snake } from './Snake.js';
import { Food } from './Food.js';
import { Renderer } from '../renderer/Renderer.js';
import { ParticleSystem } from '../renderer/ParticleSystem.js';
import { InputManager } from '../input/InputManager.js';

export class Game {
    constructor(canvasId) {
        // 获取画布
        const canvas = document.getElementById(canvasId);
        if (!canvas) {
            throw new Error(`Canvas element "${canvasId}" not found`);
        }

        // 初始化模块
        this.grid = new Grid();
        this.snake = new Snake(this.grid);
        this.food = new Food(this.grid);
        this.renderer = new Renderer(canvas);
        this.particles = new ParticleSystem();
        this.input = new InputManager();

        // 设置渲染器网格引用
        this.renderer.setGrid(this.grid);

        // 游戏状态
        this.state = GAME_STATE.IDLE;
        this.score = 0;
        this.highScore = this.loadHighScore();

        // 游戏循环
        this.lastUpdateTime = 0;
        this.gameLoopId = null;

        // 绑定UI元素
        this.bindUI();

        // 设置输入处理
        this.setupInput();

        // 初始化UI
        this.updateScoreDisplay();
        this.updateHighScoreDisplay();
    }

    /**
     * 绑定UI元素
     */
    bindUI() {
        this.startScreen = document.getElementById('start-screen');
        this.gameOverScreen = document.getElementById('game-over-screen');
        this.pauseScreen = document.getElementById('pause-screen');
        this.scoreDisplay = document.getElementById('score');
        this.highScoreDisplay = document.getElementById('high-score');
        this.finalScoreDisplay = document.getElementById('final-score');

        // 绑定按钮事件
        document.getElementById('start-btn')?.addEventListener('click', () => this.start());
        document.getElementById('restart-btn')?.addEventListener('click', () => this.restart());
        document.getElementById('resume-btn')?.addEventListener('click', () => this.resume());
    }

    /**
     * 设置输入处理
     */
    setupInput() {
        this.input.onKey((event) => {
            if (event.type === 'direction') {
                if (this.state === GAME_STATE.PLAYING) {
                    this.snake.setDirection(event.direction);
                }
            } else if (event.type === 'pause') {
                if (this.state === GAME_STATE.PLAYING) {
                    this.pause();
                } else if (this.state === GAME_STATE.PAUSED) {
                    this.resume();
                }
            }
        });

        this.input.onTouch((event) => {
            if (event.type === 'direction' && this.state === GAME_STATE.PLAYING) {
                this.snake.setDirection(event.direction);
            }
        });
    }

    /**
     * 开始游戏
     */
    start() {
        this.reset();
        this.state = GAME_STATE.PLAYING;
        this.hideAllScreens();
        this.startGameLoop();
    }

    /**
     * 重新开始
     */
    restart() {
        this.start();
    }

    /**
     * 暂停游戏
     */
    pause() {
        if (this.state !== GAME_STATE.PLAYING) return;
        
        this.state = GAME_STATE.PAUSED;
        this.pauseScreen.classList.remove('hidden');
    }

    /**
     * 继续游戏
     */
    resume() {
        if (this.state !== GAME_STATE.PAUSED) return;
        
        this.state = GAME_STATE.PLAYING;
        this.pauseScreen.classList.add('hidden');
        this.lastUpdateTime = performance.now();
    }

    /**
     * 游戏结束
     */
    gameOver() {
        this.state = GAME_STATE.GAME_OVER;
        this.stopGameLoop();

        // 更新最高分
        if (this.score > this.highScore) {
            this.highScore = this.score;
            this.saveHighScore(this.highScore);
            this.updateHighScoreDisplay();
        }

        // 显示游戏结束画面
        this.finalScoreDisplay.textContent = this.score;
        this.gameOverScreen.classList.remove('hidden');

        // 死亡特效
        const head = this.snake.getHead();
        if (head) {
            const pixel = this.grid.toPixel(head.x, head.y);
            this.particles.emitDeath(pixel.x, pixel.y);
            this.render();
        }
    }

    /**
     * 重置游戏状态
     */
    reset() {
        this.snake.reset();
        this.food.generate(this.snake.positions);
        this.particles.clear();
        this.score = 0;
        this.updateScoreDisplay();
    }

    /**
     * 隐藏所有屏幕
     */
    hideAllScreens() {
        this.startScreen?.classList.add('hidden');
        this.gameOverScreen?.classList.add('hidden');
        this.pauseScreen?.classList.add('hidden');
    }

    /**
     * 开始游戏循环
     */
    startGameLoop() {
        this.lastUpdateTime = performance.now();
        const loop = (currentTime) => {
            if (this.state === GAME_STATE.PLAYING) {
                const deltaTime = currentTime - this.lastUpdateTime;
                const speed = this.snake.getSpeed();

                if (deltaTime >= speed) {
                    this.update();
                    this.lastUpdateTime = currentTime;
                }
            }
            
            // 始终渲染（保持动画效果）
            this.render();
            this.gameLoopId = requestAnimationFrame(loop);
        };
        
        this.gameLoopId = requestAnimationFrame(loop);
    }

    /**
     * 停止游戏循环
     */
    stopGameLoop() {
        if (this.gameLoopId) {
            cancelAnimationFrame(this.gameLoopId);
            this.gameLoopId = null;
        }
    }

    /**
     * 更新游戏状态
     */
    update() {
        // 更新蛇
        this.snake.update();

        // 检查死亡
        if (!this.snake.alive) {
            this.gameOver();
            return;
        }

        // 检查吃到食物
        const foodPos = this.food.getPosition();
        if (this.snake.checkFood(foodPos)) {
            // 吃到食物
            this.score = this.snake.eatFood();
            this.updateScoreDisplay();

            // 食物特效
            const pixel = this.grid.toPixel(foodPos.x, foodPos.y);
            this.particles.emitFoodEat(pixel.x, pixel.y);

            // 生成新食物
            this.food.generate(this.snake.positions);
        }

        // 更新食物动画
        this.food.update();

        // 更新粒子
        this.particles.update();
    }

    /**
     * 渲染游戏
     */
    render() {
        this.renderer.clear();
        this.renderer.drawGrid();
        this.renderer.drawFood(this.food);
        this.renderer.drawSnake(this.snake);
        this.renderer.drawParticles(this.particles);
    }

    /**
     * 更新分数显示
     */
    updateScoreDisplay() {
        if (this.scoreDisplay) {
            this.scoreDisplay.textContent = this.score;
        }
    }

    /**
     * 更新最高分显示
     */
    updateHighScoreDisplay() {
        if (this.highScoreDisplay) {
            this.highScoreDisplay.textContent = this.highScore;
        }
    }

    /**
     * 加载最高分
     */
    loadHighScore() {
        try {
            return parseInt(localStorage.getItem('snakeHighScore')) || 0;
        } catch {
            return 0;
        }
    }

    /**
     * 保存最高分
     */
    saveHighScore(score) {
        try {
            localStorage.setItem('snakeHighScore', score.toString());
        } catch {
            // 忽略存储错误
        }
    }

    /**
     * 销毁游戏
     */
    destroy() {
        this.stopGameLoop();
        this.input.destroy();
    }
}


