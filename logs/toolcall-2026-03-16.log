{"file_path":"/Users/like/code/apptest/src/renderer/Renderer.js","new_string":"    /**\n     * 绘制圆角矩形\n     */\n    drawRoundedRect(x, y, width, height, radius) {\n        const { ctx } = this;\n        ctx.beginPath();\n        ctx.moveTo(x + radius, y);\n        ctx.lineTo(x + width - radius, y);\n        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);\n        ctx.lineTo(x + width, y + height - radius);\n        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);\n        ctx.lineTo(x + radius, y + height);\n        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);\n        ctx.lineTo(x, y + radius);\n        ctx.quadraticCurveTo(x, y, x + radius, y);\n        ctx.closePath();\n    }\n\n    /**\n     * 绘制道具/食物\n     */\n    drawPowerUp(powerUp) {\n        if (!powerUp.active) return;\n\n        const { ctx, grid } = this;\n        const { cellSize, GLOW_BLUR } = GAME_CONFIG;\n        const pixel = grid.toPixel(powerUp.position.x, powerUp.position.y);\n        const scale = powerUp.getScale();\n        const config = powerUp.config || GAME_CONFIG.POWER_UPS.NORMAL;\n        const baseSize = cellSize - 6;\n        const size = baseSize * scale;\n\n        ctx.save();\n\n        // 发光效果\n        ctx.shadowBlur = GLOW_BLUR * 2;\n        ctx.shadowColor = config.glowColor || config.color;\n        ctx.globalCompositeOperation = 'lighter';\n\n        // 根据类型绘制不同形状\n        const type = powerUp.type;\n\n        if (type === 'normal') {\n            // 菱形 - 普通食物\n            ctx.fillStyle = config.color;\n            ctx.beginPath();\n            ctx.moveTo(pixel.x, pixel.y - size / 2);\n            ctx.lineTo(pixel.x + size / 2, pixel.y);\n            ctx.lineTo(pixel.x, pixel.y + size / 2);\n            ctx.lineTo(pixel.x - size / 2, pixel.y);\n            ctx.closePath();\n            ctx.fill();\n        } else if (type === 'speed') {\n            // 闪电形状 - 加速\n            ctx.fillStyle = config.color;\n            ctx.beginPath();\n            ctx.moveTo(pixel.x + size / 4, pixel.y - size / 2);\n            ctx.lineTo(pixel.x - size / 4, pixel.y);\n            ctx.lineTo(pixel.x + size / 6, pixel.y);\n            ctx.lineTo(pixel.x - size / 6, pixel.y + size / 2);\n            ctx.lineTo(pixel.x + size / 4, pixel.y);\n            ctx.lineTo(pixel.x - size / 6, pixel.y);\n            ctx.closePath();\n            ctx.fill();\n        } else if (type === 'shield') {\n            // 六角星 - 护盾\n            ctx.fillStyle = config.color;\n            this.drawStar(pixel.x, pixel.y, 6, size / 2, size / 4);\n        } else if (type === 'growth') {\n            // 钻石形状 - 生长\n            ctx.fillStyle = config.color;\n            this.drawStar(pixel.x, pixel.y, 4, size / 2, size / 3);\n        } else if (type === 'slow') {\n            // 雪花形状 - 减速\n            ctx.fillStyle = config.color;\n            this.drawSnowflake(pixel.x, pixel.y, size / 2);\n        } else {\n            // 默认菱形\n            ctx.fillStyle = config.color;\n            ctx.beginPath();\n            ctx.moveTo(pixel.x, pixel.y - size / 2);\n            ctx.lineTo(pixel.x + size / 2, pixel.y);\n            ctx.lineTo(pixel.x, pixel.y + size / 2);\n            ctx.lineTo(pixel.x - size / 2, pixel.y);\n            ctx.closePath();\n            ctx.fill();\n        }\n\n        // 内部高光\n        ctx.fillStyle = '#ffffff';\n        ctx.globalAlpha = 0.3;\n        ctx.beginPath();\n        ctx.arc(pixel.x, pixel.y, size / 4, 0, Math.PI * 2);\n        ctx.fill();\n\n        ctx.restore();\n    }\n\n    /**\n     * 绘制星星\n     */\n    drawStar(cx, cy, spikes, outerRadius, innerRadius) {\n        const { ctx } = this;\n        let rot = Math.PI / 2 * 3;\n        let x = cx;\n        let y = cy;\n        const step = Math.PI / spikes;\n\n        ctx.beginPath();\n        ctx.moveTo(cx, cy - outerRadius);\n\n        for (let i = 0; i < spikes; i++) {\n            x = cx + Math.cos(rot) * outerRadius;\n            y = cy + Math.sin(rot) * outerRadius;\n            ctx.lineTo(x, y);\n            rot += step;\n\n            x = cx + Math.cos(rot) * innerRadius;\n            y = cy + Math.sin(rot) * innerRadius;\n            ctx.lineTo(x, y);\n            rot += step;\n        }\n\n        ctx.lineTo(cx, cy - outerRadius);\n        ctx.closePath();\n        ctx.fill();\n    }\n\n    /**\n     * 绘制雪花\n     */\n    drawSnowflake(cx, cy, radius) {\n        const { ctx } = this;\n        const arms = 6;\n\n        ctx.beginPath();\n        for (let i = 0; i < arms; i++) {\n            const angle = (i * Math.PI * 2) / arms;\n            ctx.moveTo(cx, cy);\n            ctx.lineTo(\n                cx + Math.cos(angle) * radius,\n                cy + Math.sin(angle) * radius\n            );\n        }\n        ctx.strokeStyle = ctx.fillStyle;\n        ctx.lineWidth = 2;\n        ctx.stroke();\n        ctx.fill();\n    }\n\n    /**\n     * 绘制障碍物\n     */\n    drawObstacles(obstacleManager) {\n        const { ctx, grid } = this;\n        const { cellSize, COLORS } = GAME_CONFIG;\n        const obstacles = obstacleManager.obstacles;\n\n        obstacles.forEach(obs => {\n            const pixel = grid.toPixel(obs.position.x, obs.position.y);\n            const padding = 3;\n            const size = cellSize - padding * 2;\n\n            ctx.save();\n\n            // 障碍物发光效果\n            ctx.shadowBlur = 8;\n            ctx.shadowColor = COLORS.OBSTACLES.GLOW_COLOR;\n\n            // 绘制不规则多边形障碍物\n            ctx.fillStyle = COLORS.OBSTACLES.COLOR;\n            ctx.strokeStyle = '#555577';\n            ctx.lineWidth = 1;\n\n            // 绘制带缺口的方块（模拟岩石）\n            const offset = Math.sin(obs.animationPhase) * 2;\n            ctx.beginPath();\n            ctx.moveTo(pixel.x - size / 2 + offset, pixel.y - size / 2);\n            ctx.lineTo(pixel.x + size / 2 - offset, pixel.y - size / 2);\n            ctx.lineTo(pixel.x + size / 2, pixel.y - size / 4);\n            ctx.lineTo(pixel.x + size / 2, pixel.y + size / 3);\n            ctx.lineTo(pixel.x + size / 4, pixel.y + size / 2 - offset);\n            ctx.lineTo(pixel.x - size / 3, pixel.y + size / 2);\n            ctx.lineTo(pixel.x - size / 2, pixel.y + size / 4 + offset);\n            ctx.lineTo(pixel.x - size / 2, pixel.y - size / 3);\n            ctx.closePath();\n            ctx.fill();\n            ctx.stroke();\n\n            // 内部纹理\n            ctx.fillStyle = '#333355';\n            ctx.beginPath();\n            ctx.arc(pixel.x - size / 6, pixel.y - size / 6, size / 6, 0, Math.PI * 2);\n            ctx.fill();\n\n            ctx.restore();\n        });\n    }\n\n    /**\n     * 绘制粒子\n     */\n    drawParticles(particleSystem) {\n        particleSystem.render(this.ctx);\n    }\n}","old_string":"    /**\n     * 绘制圆角矩形\n     */\n    drawRoundedRect(x, y, width, height, radius) {\n        const { ctx } = this;\n        ctx.beginPath();\n        ctx.moveTo(x + radius, y);\n        ctx.lineTo(x + width - radius, y);\n        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);\n        ctx.lineTo(x + width, y + height - radius);\n        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);\n        ctx.lineTo(x + radius, y + height);\n        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);\n        ctx.lineTo(x, y + radius);\n        ctx.quadraticCurveTo(x, y, x + radius, y);\n        ctx.closePath();\n    }\n\n    /**\n     * 绘制粒子\n     */\n    drawParticles(particleSystem) {\n        particleSystem.render(this.ctx);\n    }\n}"}


