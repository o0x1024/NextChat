/**
 * 游戏渲染器 - 负责所有视觉元素的绘制
 */
import { GAME_CONFIG } from '../utils/constants.js';

export class Renderer {
    constructor(canvas) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.grid = null;
        
        // 调整画布尺寸
        this.resize();
    }

    /**
     * 调整画布尺寸
     */
    resize() {
        const container = this.canvas.parentElement;
        const size = Math.min(container.clientWidth, container.clientHeight);
        
        this.canvas.width = GAME_CONFIG.CANVAS_WIDTH;
        this.canvas.height = GAME_CONFIG.CANVAS_HEIGHT;
        
        this.ctx.imageSmoothingEnabled = false;
    }

    /**
     * 设置网格引用
     */
    setGrid(grid) {
        this.grid = grid;
    }

    /**
     * 清空画布
     */
    clear() {
        const { ctx, canvas } = this;
        ctx.fillStyle = GAME_CONFIG.COLORS.BACKGROUND;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    /**
     * 绘制网格背景
     */
    drawGrid() {
        const { ctx, grid } = this;
        const { cellSize, COLORS } = GAME_CONFIG;

        ctx.strokeStyle = COLORS.GRID_LINE;
        ctx.lineWidth = 0.5;

        // 绘制垂直线
        for (let x = 0; x <= grid.cols; x++) {
            ctx.beginPath();
            ctx.moveTo(x * cellSize, 0);
            ctx.lineTo(x * cellSize, grid.height);
            ctx.stroke();
        }

        // 绘制水平线
        for (let y = 0; y <= grid.rows; y++) {
            ctx.beginPath();
            ctx.moveTo(0, y * cellSize);
            ctx.lineTo(grid.width, y * cellSize);
            ctx.stroke();
        }

        // 绘制网格点
        ctx.fillStyle = COLORS.GRID_DOT;
        for (let x = 0; x < grid.cols; x++) {
            for (let y = 0; y < grid.rows; y++) {
                ctx.beginPath();
                ctx.arc(
                    x * cellSize + cellSize / 2,
                    y * cellSize + cellSize / 2,
                    1, 0, Math.PI * 2
                );
                ctx.fill();
            }
        }
    }

    /**
     * 绘制蛇
     */
    drawSnake(snake) {
        const { ctx, grid } = this;
        const { cellSize, COLORS, GLOW_BLUR } = GAME_CONFIG;
        const positions = snake.positions;

        if (positions.length === 0) return;

        // 绘制蛇身（从尾部到头部）
        for (let i = positions.length - 1; i >= 0; i--) {
            const pos = positions[i];
            const pixel = grid.toPixel(pos.x, pos.y);
            const isHead = i === 0;
            
            // 计算渐变色
            const gradientPos = i / positions.length;
            const colorIndex = Math.floor(gradientPos * (COLORS.SNAKE_BODY_GRADIENT.length - 1));
            const color = isHead ? COLORS.SNAKE_HEAD : COLORS.SNAKE_BODY_GRADIENT[colorIndex] || COLORS.SNAKE_HEAD;

            // 发光效果
            ctx.save();
            ctx.shadowBlur = isHead ? GLOW_BLUR * 1.5 : GLOW_BLUR;
            ctx.shadowColor = color;
            
            // 绘制圆角矩形
            const padding = 2;
            const size = cellSize - padding * 2;
            const radius = isHead ? size / 2 : size / 3;

            this.drawRoundedRect(
                pixel.x - size / 2,
                pixel.y - size / 2,
                size, size,
                radius
            );

            // 填充
            ctx.fillStyle = color;
            ctx.globalCompositeOperation = 'lighter';
            ctx.fill();
            
            // 蛇头眼睛
            if (isHead) {
                ctx.fillStyle = '#ffffff';
                const eyeSize = size / 5;
                const eyeOffset = size / 4;
                
                // 根据方向绘制眼睛
                const { direction } = snake;
                if (direction.x === 1) { // 向右
                    ctx.beginPath();
                    ctx.arc(pixel.x + eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.arc(pixel.x + eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.fill();
                } else if (direction.x === -1) { // 向左
                    ctx.beginPath();
                    ctx.arc(pixel.x - eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.arc(pixel.x - eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.fill();
                } else if (direction.y === -1) { // 向上
                    ctx.beginPath();
                    ctx.arc(pixel.x - eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.arc(pixel.x + eyeOffset, pixel.y - eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.fill();
                } else { // 向下
                    ctx.beginPath();
                    ctx.arc(pixel.x - eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.arc(pixel.x + eyeOffset, pixel.y + eyeOffset, eyeSize, 0, Math.PI * 2);
                    ctx.fill();
                }
            }
            
            ctx.restore();
        }
    }

    /**
     * 绘制食物
     */
    drawFood(food) {
        if (!food.active) return;

        const { ctx, grid } = this;
        const { cellSize, GLOW_BLUR } = GAME_CONFIG;
        const pixel = grid.toPixel(food.position.x, food.position.y);
        const scale = food.getScale();
        const baseSize = cellSize - 6;
        const size = baseSize * scale;

        ctx.save();
        
        // 发光效果
        ctx.shadowBlur = GLOW_BLUR * 2;
        ctx.shadowColor = food.getGlowColor();
        ctx.globalCompositeOperation = 'lighter';

        // 绘制菱形食物
        ctx.fillStyle = food.getColor();
        ctx.beginPath();
        ctx.moveTo(pixel.x, pixel.y - size / 2);
        ctx.lineTo(pixel.x + size / 2, pixel.y);
        ctx.lineTo(pixel.x, pixel.y + size / 2);
        ctx.lineTo(pixel.x - size / 2, pixel.y);
        ctx.closePath();
        ctx.fill();

        // 内部高光
        ctx.fillStyle = '#ffffff';
        ctx.globalAlpha = 0.3;
        ctx.beginPath();
        ctx.arc(pixel.x, pixel.y, size / 4, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
    }

    /**
     * 绘制圆角矩形
     */
    drawRoundedRect(x, y, width, height, radius) {
        const { ctx } = this;
        ctx.beginPath();
        ctx.moveTo(x + radius, y);
        ctx.lineTo(x + width - radius, y);
        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
        ctx.lineTo(x + width, y + height - radius);
        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
        ctx.lineTo(x + radius, y + height);
        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
        ctx.lineTo(x, y + radius);
        ctx.quadraticCurveTo(x, y, x + radius, y);
        ctx.closePath();
    }

    /**
     * 绘制粒子
     */
    drawParticles(particleSystem) {
        particleSystem.render(this.ctx);
    }
}


