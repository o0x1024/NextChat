        this.updateHighScoreDisplay();\\n        this.setupModeButtons();\\n    }\\n\\n    /**\\n     * 绑定UI元素\\n     */\\n    bindUI() {\\n        this.startScreen = document.getElementById('start-screen');\\n        this.gameOverScreen = document.getElementById('game-over-screen');\\n        this.pauseScreen = document.getElementById('pause-screen');\\n        this.scoreDisplay = document.getElementById('score');\\n        this.highScoreDisplay = document.getElementById('high-score');\\n        this.finalScoreDisplay = document.getElementById('final-score');\\n        this.modeDisplay = document.getElementById('mode-display');\\n        this.timeDisplay = document.getElementById('time-display');\\n\\n        // 绑定按钮事件\\n        document.getElementById('start-btn')?.addEventListener('click', () => this.start());\\n        document.getElementById('restart-btn')?.addEventListener('click', () => this.restart());\\n        document.getElementById('resume-btn')?.addEventListener('click', () => this.resume());\\n\\n        // 模式选择按钮\\n        this.setupModeButtons();\\n    }\\n\\n    /**\\n     * 设置模式选择按钮\\n     */\\n    setupModeButtons() {\\n        const modes = [\\n            { id: 'classic-btn', mode: GAME_MODE.CLASSIC },\\n            { id: 'challenge-btn', mode: GAME_MODE.CHALLENGE },\\n            { id: 'time-attack-btn', mode: GAME_MODE.TIME_ATTACK },\\n            { id: 'endless-btn', mode: GAME_MODE.ENDLESS }\\n        ];\\n\\n        modes.forEach(({ id, mode }) => {\\n            const btn = document.getElementById(id);\\n            if (btn) {\\n                btn.addEventListener('click', () => {\\n                    this.currentMode = mode;\\n                    this.gameModeManager.setMode(mode);\\n                    this.start();\\n                });\\n            }\\n        });\\n    }\\n\\n    /**\\n     * 设置输入处理\\n     */\\n    setupInput() {\\n        this.input.onKey((event) => {\\n            if (event.type === 'direction') {\\n                if (this.state === GAME_STATE.PLAYING) {\\n                    this.snake.setDirection(event.direction);\\n                }\\n            } else if (event.type === 'pause') {\\n                if (this.state === GAME_STATE.PLAYING) {\\n                    this.pause();\\n                } else if (this.state === GAME_STATE.PAUSED) {\\n                    this.resume();\\n                }\\n            }\\n        });\\n\\n        this.input.onTouch((event) => {\\n            if (event.type === 'direction' && this.state === GAME_STATE.PLAYING) {\\n                this.snake.setDirection(event.direction);\\n            }\\n        });\\n    }\\n\\n    /**\\n     * 开始游戏\\n     */\\n    start() {\\n        this.reset();\\n        this.state = GAME_STATE.PLAYING;\\n        this.hideAllScreens();\\n\\n        // 设置游戏模式\\n        this.gameModeManager.setMode(this.currentMode);\\n        this.gameModeManager.startMode();\\n\\n        // 初始化障碍物（根据模式）\\n        const mode = this.gameModeManager.getCurrentMode();\\n        const obstacleCount = mode.getObstacleCount();\\n        this.obstacleManager.initialize(this.snake.positions, obstacleCount);\\n\\n        // 生成食物\\n        const occupiedPositions = [...this.snake.positions, ...this.obstacleManager.getPositions()];\\n        this.powerUp.generateFood(occupiedPositions);\\n\\n        // 清除蛇的特殊状态\\n        this.snake.clearEffects();\\n\\n        this.updateModeDisplay();\\n        this.startGameLoop();\\n    }\\n\\n    /**\\n     * 重新开始\\n     */\\n    restart() {\\n        this.start();\\n    }\\n\\n    /**\\n     * 暂停游戏\\n     */\\n    pause() {\\n        if (this.state !== GAME_STATE.PLAYING) return;\\n\\n        this.state = GAME_STATE.PAUSED;\\n        this.pauseScreen.classList.remove('hidden');\\n    }\\n\\n    /**\\n     * 继续游戏\\n     */\\n    resume() {\\n        if (this.state !== GAME_STATE.PAUSED) return;\\n\\n        this.state = GAME_STATE.PLAYING;\\n        this.pauseScreen.classList.add('hidden');\\n        this.lastUpdateTime = performance.now();\\n        this.lastFrameTime = performance.now();\\n    }\\n\\n    /**\\n     * 游戏结束\\n     */\\n    gameOver() {\\n        this.state = GAME_STATE.GAME_OVER;\\n        this.stopGameLoop();\\n        this.gameModeManager.stopMode();\\n\\n        // 更新最高分\\n        if (this.score > this.highScore) {\\n            this.highScore = this.score;\\n            this.saveHighScore(this.highScore);\\n            this.updateHighScoreDisplay();\\n        }\\n\\n        // 显示游戏结束画面\\n        this.finalScoreDisplay.textContent = this.score;\\n        this.gameOverScreen.classList.remove('hidden');\\n\\n        // 死亡特效\\n        const head = this.snake.getHead();\\n        if (head) {\\n            const pixel = this.grid.toPixel(head.x, head.y);\\n            this.particles.emitDeath(pixel.x, pixel.y);\\n            this.render();\\n        }\\n    }\\n\\n    /**\\n     * 游戏时间结束（限时模式）\\n     */\\n    timeOver() {\\n        this.gameOver();\\n    }\\n\\n    /**\\n     * 重置游戏状态\\n     */\\n    reset() {\\n        this.snake.reset();\\n        this.powerUpManager.clearAll();\\n        this.obstacleManager.clear();\\n        this.particles.clear();\\n        this.score = 0;\\n        this.updateScoreDisplay();\\n    }\\n\\n    /**\\n     * 隐藏所有屏幕\\n     */\\n    hideAllScreens() {\\n        this.startScreen?.classList.add('hidden');\\n        this.gameOverScreen?.classList.add('hidden');\\n        this.pauseScreen?.classList.add('hidden');\\n    }\\n\\n    /**\\n     * 开始游戏循环\\n     */\\n    startGameLoop() {\\n        this.lastUpdateTime = performance.now();\\n        this.lastFrameTime = performance.now();\\n\\n        const loop = (currentTime) => {\\n            const deltaTime = currentTime - this.lastFrameTime;\\n            this.lastFrameTime = currentTime;\\n\\n            if (this.state === GAME_STATE.PLAYING) {\\n                const speed = this.snake.getSpeed();\\n\\n                // 更新时间（限时模式）\\n                const mode = this.gameModeManager.getCurrentMode();\\n                if (mode.hasTimeLimit()) {\\n                    const timeUp = mode.updateTime(deltaTime);\\n                    this.updateTimeDisplay();\\n                    if (timeUp) {\\n                        this.timeOver();\\n                        return;\\n                    }\\n                }\\n\\n                // 更新效果管理器\\n                this.powerUpManager.update(deltaTime);\\n\\n                // 检查蛇的状态\\n                this.snake.hasShield = this.powerUpManager.hasShield();\\n                this.snake.speedBoost = this.powerUpManager.isSpeedBoost();\\n                this.snake.slowed = this.powerUpManager.isSlowed();\\n\\n                const deltaTimeSinceUpdate = currentTime - this.lastUpdateTime;\\n                if (deltaTimeSinceUpdate >= speed) {\\n                    this.update();\\n                    this.lastUpdateTime = currentTime;\\n                }\\n            }\\n\\n            // 始终渲染（保持动画效果）\\n            this.render();\\n            this.gameLoopId = requestAnimationFrame(loop);\\n        };\\n\\n        this.gameLoopId = requestAnimationFrame(loop);\\n    }\\n\\n    /**\\n     * 停止游戏循环\\n     */\\n    stopGameLoop() {\\n        if (this.gameLoopId) {\\n            cancelAnimationFrame(this.gameLoopId);\\n            this.gameLoopId = null;\\n        }\\n    }\\n\\n    /**\\n     * 更新游戏状态\\n     */\\n    update() {\\n        // 更新蛇\\n        this.snake.update();\\n\\n        // 检查死亡\\n        if (!this.snake.alive) {\\n            this.gameOver();\\n            return;\\n        }\\n\\n        // 检查是否撞到障碍物\\n        const head = this.snake.getHead();\\n        if (this.obstacleManager.hasObstacle(head.x, head.y)) {\\n            if (!this.snake.hasShield) {\\n                this.gameOver();\\n                return;\\n            }\\n        }\\n\\n        // 检查吃到道具\\n        if (this.powerUp.isActive() && this.snake.checkFood(this.powerUp.position)) {\\n            // 