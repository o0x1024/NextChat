ghScoreDisplay() {\\n        if (this.highScoreDisplay) {\\n            this.highScoreDisplay.textContent = this.highScore;\\n        }\\n    }\\n\\n    /**\\n     * 更新模式显示\\n     */\\n    updateModeDisplay() {\\n        if (this.modeDisplay) {\\n            const mode = this.gameModeManager.getCurrentMode();\\n            this.modeDisplay.textContent = mode.getName();\\n        }\\n    }\\n\\n    /**\\n     * 更新时间显示（限时模式）\\n     */\\n    updateTimeDisplay() {\\n        if (this.timeDisplay) {\\n            const mode = this.gameModeManager.getCurrentMode();\\n            this.timeDisplay.textContent = mode.getTimeRemainingSeconds();\\n        }\\n    }\\n\\n    /**\\n     * 加载最高分\\n     */\\n    loadHighScore() {\\n        try {\\n            return parseInt(localStorage.getItem('snakeHighScore')) || 0;\\n        } catch {\\n            return 0;\\n        }\\n    }\\n\\n    /**\\n     * 保存最高分\\n     */\\n    saveHighScore(score) {\\n        try {\\n            localStorage.setItem('snakeHighScore', score.toString());\\n        } catch {\\n            // 忽略存储错误\\n        }\\n    }\\n\\n    /**\\n     * 销毁游戏\\n     */\\n    destroy() {\\n        this.stopGameLoop();\\n        this.input.destroy();\\n    }\\n}\"","output":"Toolset error: ToolCallError: ToolCallError: ToolCallError: Edit expects JSON object input"}
