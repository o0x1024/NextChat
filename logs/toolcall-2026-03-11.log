1	package com.suyu.secexample.ssrf.utils;
 2	
 3	import java.io.*;
 4	import java.net.URL;
 5	import java.net.URLConnection;
 6	
 7	//URLConnection:可以走邮件、文件传输协议。
 8	//HttpURLConnection 只能走浏览器的HTTP协议
 9	
10	public class HttpTool {
11	    public static Object httpRequest(String requestUrl) throws Exception {
12	        String htmlContent;
13	        URL url = new URL(requestUrl);
14	        URLConnection urlConnection = url.openConnection();
15	        //HttpURLConnection httpUrl = (HttpURLConnection) urlConnection;
16	        BufferedReader base = new BufferedReader(new InputStreamReader(urlConnection.getInputStream(), "UTF-8"));
17	        StringBuffer html = new StringBuffer();
18	        while ((htmlContent = base.readLine()) != null) {
19	            html.append(htmlContent);
20	        }
21	        base.close();
22	        return html;
23	    }
24	
25	    public static Object getHttpReuest(String requestUrl) throws Exception {
26	        return  httpRequest(requestUrl);
27	    }
28	}
29


