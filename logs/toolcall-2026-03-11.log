20	        return "rce/rce";
21	    }
22	
23	
24	    @PostMapping("/rceoutput")
25	    public String index(@RequestParam("command") String command, Model model){
26	        if(command=="" | command==null){
27	            command= "whoami";
28	        }
29	        Process p = null;
30	        String result = null;
31	        try {
32	            p = Runtime.getRuntime().exec(command);
33	        } catch (IOException e) {
34	            e.printStackTrace();
35	        }
36	        InputStream is = p.getInputStream();
37	        BufferedReader reader = new BufferedReader(new InputStreamReader(is));
38	        String s = null;
39	        while (true) {
40	            try {
41	                if (!((s = reader.readLine()) != null)) break;
42	            } catch (IOException e) {
43	                e.printStackTrace();
44	            }
45	            result = s;
46	        }
47	        model.addAttribute("result",result);
48	        return "rce/rceoutput";
49	    }
50	
51	}


